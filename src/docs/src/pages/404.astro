---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>404 · Pinglab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var resolved =
            stored === "light" || stored === "dark"
              ? stored
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.setAttribute("data-theme", resolved);
        } catch (e) {}
      })();
    </script>
    <style>
      .nf-wrap {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1.6rem;
        padding: 2rem;
        font-family: var(--font-mono);
      }
      /* All three elements share the 404's left edge; the stack is centered
         on the page as one block. */
      .nf-stack {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 1.6rem;
        text-align: left;
      }
      .nf-code {
        position: relative;
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-weight: 700;
        font-size: clamp(5rem, 22vw, 11rem);
        line-height: 0.9;
        letter-spacing: 0.04em;
        color: var(--ink);
        user-select: none;
      }
      /* Black at rest; a single red ghost tears through for a fraction of a
         second every few seconds. No cyan. */
      .nf-code::before {
        content: attr(data-text);
        position: absolute;
        inset: 0;
        opacity: 0;
        pointer-events: none;
        color: var(--color-cat-red);
        animation: nf-glitch 2.8s infinite steps(2, end);
      }
      @keyframes nf-glitch {
        0%, 86%, 100% { opacity: 0; transform: translate(0, 0); clip-path: none; }
        88% { opacity: 0.9; transform: translate(-3px, 1px); clip-path: inset(0 0 62% 0); }
        92% { opacity: 0.9; transform: translate(2px, -1px); clip-path: inset(58% 0 0 0); }
      }
      @media (prefers-reduced-motion: reduce) {
        .nf-code::before { animation: none; }
      }
      .nf-body {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 1.5rem;
        max-width: 30rem;
        text-align: left;
      }
      .nf-poem {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 1.05rem;
        line-height: 1.8;
        color: var(--color-muted);
      }
      .nf-home {
        font-size: 0.85rem;
        color: var(--ink);
        text-decoration: none;
        border-bottom: 2px solid var(--color-cat-red);
        padding-bottom: 2px;
      }
      .nf-home:hover { color: var(--color-cat-red); }
    </style>
  </head>
  <body>
    <div class="fixed top-4 right-4 z-40">
      <ThemeToggle />
    </div>

    <main class="nf-wrap">
      <div class="nf-stack">
        <div class="nf-code" data-text="404">404</div>
        <div class="nf-body">
          <p class="nf-poem">Spike failed</p>
          <a class="nf-home" href="/">reset to rest</a>
        </div>
      </div>
    </main>
  </body>
</html>
