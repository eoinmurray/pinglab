---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";

const notebookModules = import.meta.glob("./notebooks/*.mdx", { eager: true });
const numbersModules = import.meta.glob("../../public/figures/notebooks/*/numbers.json", {
  eager: true,
  import: "default",
});
const numbersBySlug: Record<string, any> = {};
for (const [path, data] of Object.entries(numbersModules)) {
  const slug = path.split("/").slice(-2, -1)[0];
  if (slug) numbersBySlug[slug] = data;
}

const runMarkers = import.meta.glob("../../public/figures/notebooks/*/_run.txt", {
  eager: true,
  query: "?raw",
  import: "default",
});
const hasRunDir = new Set<string>();
for (const path of Object.keys(runMarkers)) {
  const slug = path.split("/").slice(-2, -1)[0];
  if (slug) hasRunDir.add(slug);
}

function badgeFor(slug: string) {
  const nums = numbersBySlug[slug];
  const criteria = Array.isArray(nums?.success_criteria) ? nums.success_criteria : [];
  const total = criteria.length;
  if (total === 0) {
    if (hasRunDir.has(slug)) return { running: true };
    return null;
  }
  const passed = criteria.filter((c: any) => c && c.passed).length;
  return { total, passed, allPass: passed === total, running: false };
}

function tierFor(slug: string): string | null {
  const nums = numbersBySlug[slug];
  if (!nums) return null;
  const t = nums.tier ?? nums.config?.tier ?? null;
  return t ? String(t) : null;
}

const notebooks = Object.entries(notebookModules)
  .map(([path, mod]) => {
    const slug = path
      .split("/")
      .pop()
      .replace(/\.mdx$/, "");
    const fm = mod.frontmatter;
    return {
      slug,
      entry: fm.entry,
      title: String(fm.title).replace(/^\d+\s*[—–-]\s*/, ""),
      date: fm.date,
      collections: Array.isArray(fm.collections) ? fm.collections : [],
      badge: badgeFor(slug),
      tier: tierFor(slug),
    };
  })
  .sort((a, b) => b.entry - a.entry);

// Group notebooks by collection. Each notebook appears under every
// collection it belongs to. Collections are ordered by size desc,
// then alphabetically.
const collectionCounts = new Map<string, number>();
for (const nb of notebooks) {
  for (const c of nb.collections) collectionCounts.set(c, (collectionCounts.get(c) ?? 0) + 1);
}
const collectionOrder = [...collectionCounts.entries()]
  .sort((a, b) => {
    if (a[0] === "in-progress") return -1;
    if (b[0] === "in-progress") return 1;
    return b[1] - a[1] || a[0].localeCompare(b[0]);
  })
  .map(([c]) => c);
const groupedByCollection = collectionOrder.map((collection) => ({
  collection,
  notebooks: notebooks.filter((nb) => nb.collections.includes(collection)),
}));
const uncollected = notebooks.filter((nb) => nb.collections.length === 0);

const articleModules = import.meta.glob("./articles/*.mdx", { eager: true });
const articles = Object.entries(articleModules)
  .map(([path, mod]) => {
    const slug = path
      .split("/")
      .pop()
      .replace(/\.mdx$/, "");
    const fm = mod.frontmatter;
    return {
      slug,
      entry: fm.entry,
      title: String(fm.title).replace(/^\d+\s*[—–-]\s*/, ""),
      date: fm.date,
    };
  })
  .sort((a, b) => b.entry - a.entry);

const formatDate = (raw) => {
  const d =
    raw instanceof Date
      ? raw
      : new Date(String(raw).includes("T") ? String(raw) : String(raw) + "T00:00:00Z");
  if (isNaN(d.getTime())) return String(raw);
  const day = d.getUTCDate();
  const suffix =
    day % 100 >= 11 && day % 100 <= 13
      ? "th"
      : day % 10 === 1
        ? "st"
        : day % 10 === 2
          ? "nd"
          : day % 10 === 3
            ? "rd"
            : "th";
  const month = d.toLocaleDateString("en-GB", { month: "short", timeZone: "UTC" });
  const year = d.getUTCFullYear();
  return `${day}${suffix} ${month} ${year}`;
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Pinglab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var resolved =
            stored === "light" || stored === "dark"
              ? stored
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.setAttribute("data-theme", resolved);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <div class="fixed top-4 right-4 z-40">
      <ThemeToggle />
    </div>
    <main class="px-6 pt-16 pb-64 lg:px-12 [&_a]:no-underline! [&_a:hover]:underline!">
      <div class="max-w-[90rem] mx-auto">
        <div class="flex items-baseline gap-4">
          <h1
            class="text-2xl font-bold"
            style="font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;"
          >
            PINGLAB
          </h1>
          <a
            href="https://github.com/eoinmurray/pinglab"
            class="text-sm text-muted hover:text-[color:var(--ink)]"
            target="_blank"
            rel="noopener">github</a
          >
        </div>

        <div class="mt-10 flex flex-col gap-12 max-w-3xl">
          <section>
            <p class="mb-2 text-xs uppercase tracking-wider text-muted">Articles</p>
            {
              articles.length > 0 ? (
                <ol class="pl-0 list-none m-0 text-[0.95rem]">
                  {articles.map((a) => (
                    <li class="flex items-baseline gap-3 py-[0.3rem]">
                      <a
                        href={`/articles/${a.slug}/`}
                        class="w-4 shrink-0 tabular-nums text-muted-soft"
                      >
                        {String(a.entry).padStart(1, "0")}.
                      </a>
                      <a href={`/articles/${a.slug}/`} class="flex-1 min-w-0">
                        {a.title}
                      </a>
                      <span class="shrink-0 whitespace-nowrap tabular-nums text-[0.85rem] text-muted-soft">
                        {formatDate(a.date)}
                      </span>
                    </li>
                  ))}
                </ol>
              ) : (
                <p class="text-sm text-muted">None yet.</p>
              )
            }
          </section>

          <section>
            <p class="mb-2 text-xs uppercase tracking-wider text-muted">Notebooks</p>
            <ol class="pl-0 list-none m-0 text-[0.95rem]">
              {
                notebooks.map((nb) => (
                  <li class="flex items-baseline gap-3 py-[0.3rem]">
                    <a
                      href={`/notebooks/${nb.slug}/`}
                      class="w-4 shrink-0 tabular-nums text-muted-soft"
                    >
                      {String(nb.entry).padStart(1, "0")}.
                    </a>
                    <a href={`/notebooks/${nb.slug}/`} class="flex-1 min-w-0">
                      {nb.title}
                    </a>
                    <span class="shrink-0 whitespace-nowrap tabular-nums text-[0.85rem] text-muted-soft">
                      {formatDate(nb.date)}
                    </span>
                  </li>
                ))
              }
            </ol>
          </section>
        </div>
      </div>
    </main>
  </body>
</html>
