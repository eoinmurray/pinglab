---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import SiteHeader from "../components/SiteHeader.astro";

const notebookModules = import.meta.glob("./notebooks/*.mdx", { eager: true });
const articleModules = import.meta.glob("./articles/*.mdx", { eager: true });
const numbersModules = import.meta.glob("../../public/figures/notebooks/*/numbers.json", {
  eager: true,
  import: "default",
});
const numbersBySlug: Record<string, any> = {};
for (const [path, data] of Object.entries(numbersModules)) {
  const slug = path.split("/").slice(-2, -1)[0];
  if (slug) numbersBySlug[slug] = data;
}

const runMarkers = import.meta.glob("../../public/figures/notebooks/*/_run.txt", {
  eager: true,
  query: "?raw",
  import: "default",
});
const hasRunDir = new Set<string>();
for (const path of Object.keys(runMarkers)) {
  const slug = path.split("/").slice(-2, -1)[0];
  if (slug) hasRunDir.add(slug);
}

function badgeFor(slug: string) {
  const nums = numbersBySlug[slug];
  const criteria = Array.isArray(nums?.success_criteria) ? nums.success_criteria : [];
  const total = criteria.length;
  if (total === 0) {
    if (hasRunDir.has(slug)) return { running: true };
    return null;
  }
  const passed = criteria.filter((c: any) => c && c.passed).length;
  return { total, passed, allPass: passed === total, running: false };
}

function tierFor(slug: string): string | null {
  const nums = numbersBySlug[slug];
  if (!nums) return null;
  const t = nums.tier ?? nums.config?.tier ?? null;
  return t ? String(t) : null;
}

type Entry = {
  slug: string;
  entry: number;
  title: string;
  date: any;
  collection: string | null;
};

function entryCollection(fm: any): string | null {
  if (typeof fm?.collection === "string" && fm.collection.length > 0) {
    return fm.collection;
  }
  return null;
}

const articles: Entry[] = Object.entries(articleModules)
  .map(([path, mod]: [string, any]) => {
    const slug = path.split("/").pop()!.replace(/\.mdx$/, "");
    const fm = mod.frontmatter;
    return {
      slug,
      entry: fm.entry,
      title: String(fm.title).replace(/^\d+\s*[—–-]\s*/, ""),
      date: fm.date,
      collection: entryCollection(fm),
    };
  })
  .sort((a, b) => b.entry - a.entry);

const notebooks = Object.entries(notebookModules)
  .map(([path, mod]: [string, any]) => {
    const slug = path.split("/").pop()!.replace(/\.mdx$/, "");
    const fm = mod.frontmatter;
    return {
      slug,
      entry: fm.entry,
      title: String(fm.title).replace(/^\d+\s*[—–-]\s*/, ""),
      date: fm.date,
      collection: entryCollection(fm),
      badge: badgeFor(slug),
      tier: tierFor(slug),
    };
  })
  .sort((a, b) => b.entry - a.entry);

// Bucket articles + notebooks by collection. Items without a
// collection land in the synthetic "__uncollected" bucket, which
// renders last under the label "Uncollected".
const UNCOLLECTED = "__uncollected";
type Bucket = {
  collection: string;
  label: string;
  articles: typeof articles;
  notebooks: typeof notebooks;
};
const bucketByName = new Map<string, Bucket>();
function getBucket(name: string): Bucket {
  if (!bucketByName.has(name)) {
    bucketByName.set(name, {
      collection: name,
      label:
        name === UNCOLLECTED
          ? "Misc"
          : name.charAt(0).toUpperCase() + name.slice(1).replace(/-/g, " "),
      articles: [],
      notebooks: [],
    });
  }
  return bucketByName.get(name)!;
}
for (const a of articles) getBucket(a.collection ?? UNCOLLECTED).articles.push(a);
for (const n of notebooks) getBucket(n.collection ?? UNCOLLECTED).notebooks.push(n);

// Order: in-progress floats first; uncollected goes last; otherwise
// rank by total count desc, then alphabetical.
const buckets = [...bucketByName.values()].sort((a, b) => {
  if (a.collection === "in-progress") return -1;
  if (b.collection === "in-progress") return 1;
  if (a.collection === UNCOLLECTED) return 1;
  if (b.collection === UNCOLLECTED) return -1;
  const totA = a.articles.length + a.notebooks.length;
  const totB = b.articles.length + b.notebooks.length;
  return totB - totA || a.collection.localeCompare(b.collection);
});

const formatDate = (raw: any) => {
  const d =
    raw instanceof Date
      ? raw
      : new Date(String(raw).includes("T") ? String(raw) : String(raw) + "T00:00:00Z");
  if (isNaN(d.getTime())) return String(raw);
  const day = d.getUTCDate();
  const suffix =
    day % 100 >= 11 && day % 100 <= 13
      ? "th"
      : day % 10 === 1
        ? "st"
        : day % 10 === 2
          ? "nd"
          : day % 10 === 3
            ? "rd"
            : "th";
  const month = d.toLocaleDateString("en-GB", { month: "short", timeZone: "UTC" });
  const year = d.getUTCFullYear();
  return `${day}${suffix} ${month} ${year}`;
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Pinglab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var resolved =
            stored === "light" || stored === "dark"
              ? stored
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.setAttribute("data-theme", resolved);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <div class="fixed top-4 right-4 z-40">
      <ThemeToggle />
    </div>
    <header class="px-6 pt-16 lg:pl-[25%] lg:pr-16 [&_a]:no-underline! [&_a:hover]:underline!">
      <div class="max-w-[46rem]">
        <SiteHeader isHome={true} />
      </div>
    </header>

    <main class="px-6 pt-10 pb-48 lg:pl-[25%] lg:pr-16 [&_a]:no-underline! [&_a:hover]:underline!">
      <div class="max-w-[46rem]">
        <div class="flex flex-col gap-12">
          {
            buckets.map((bucket) => (
              <section>
                <p class="mb-2 text-xs uppercase tracking-wider text-muted">
                  {bucket.collection === UNCOLLECTED ? (
                    bucket.label
                  ) : (
                    <a href={`/collections/${bucket.collection}/`}>{bucket.label}</a>
                  )}
                </p>

                {bucket.articles.length > 0 && (
                  <ol class="pl-0 list-none m-0 text-[0.95rem]">
                    {bucket.articles.map((a) => (
                      <li class="flex items-baseline gap-3 py-[0.3rem]">
                        <a
                          href={`/articles/${a.slug}/`}
                          class="shrink-0 font-mono tabular-nums text-[0.85rem] text-muted-soft"
                        >
                          {a.slug}
                        </a>
                        <a href={`/articles/${a.slug}/`} class="flex-1 min-w-0">
                          {a.title}
                        </a>
                        <span class="shrink-0 whitespace-nowrap tabular-nums text-[0.85rem] text-muted-soft">
                          {formatDate(a.date)}
                        </span>
                      </li>
                    ))}
                  </ol>
                )}

                {bucket.notebooks.length > 0 && (
                  <ol class="pl-0 list-none m-0 text-[0.95rem]">
                    {bucket.notebooks.map((nb) => (
                      <li class="flex items-baseline gap-3 py-[0.3rem]">
                        <a
                          href={`/notebooks/${nb.slug}/`}
                          class="shrink-0 font-mono tabular-nums text-[0.85rem] text-muted-soft"
                        >
                          {nb.slug}
                        </a>
                        <a href={`/notebooks/${nb.slug}/`} class="flex-1 min-w-0">
                          {nb.title}
                        </a>
                        <span class="shrink-0 whitespace-nowrap tabular-nums text-[0.85rem] text-muted-soft">
                          {formatDate(nb.date)}
                        </span>
                      </li>
                    ))}
                  </ol>
                )}
              </section>
            ))
          }
        </div>
      </div>
    </main>
  </body>
</html>
