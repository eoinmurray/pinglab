---
import "../styles/global.css";

const notebookModules = import.meta.glob("./notebooks/*.mdx", { eager: true });
const numbersModules = import.meta.glob("../../public/figures/notebooks/*/numbers.json", {
  eager: true,
  import: "default",
});
const numbersBySlug: Record<string, any> = {};
for (const [path, data] of Object.entries(numbersModules)) {
  const slug = path.split("/").slice(-2, -1)[0];
  if (slug) numbersBySlug[slug] = data;
}

const runMarkers = import.meta.glob("../../public/figures/notebooks/*/_run.txt", {
  eager: true,
  query: "?raw",
  import: "default",
});
const hasRunDir = new Set<string>();
for (const path of Object.keys(runMarkers)) {
  const slug = path.split("/").slice(-2, -1)[0];
  if (slug) hasRunDir.add(slug);
}

function badgeFor(slug: string) {
  const nums = numbersBySlug[slug];
  const criteria = Array.isArray(nums?.success_criteria) ? nums.success_criteria : [];
  const total = criteria.length;
  if (total === 0) {
    if (hasRunDir.has(slug)) return { running: true };
    return null;
  }
  const passed = criteria.filter((c: any) => c && c.passed).length;
  return { total, passed, allPass: passed === total, running: false };
}

function tierFor(slug: string): string | null {
  const nums = numbersBySlug[slug];
  if (!nums) return null;
  const t = nums.tier ?? nums.config?.tier ?? null;
  return t ? String(t) : null;
}

const notebooks = Object.entries(notebookModules)
  .map(([path, mod]) => {
    const slug = path
      .split("/")
      .pop()
      .replace(/\.mdx$/, "");
    const fm = mod.frontmatter;
    return {
      slug,
      entry: fm.entry,
      title: String(fm.title).replace(/^\d+\s*[—–-]\s*/, ""),
      date: fm.date,
      collections: Array.isArray(fm.collections) ? fm.collections : [],
      badge: badgeFor(slug),
      tier: tierFor(slug),
    };
  })
  .sort((a, b) => -b.entry + a.entry);

// Group notebooks by collection. Each notebook appears under every
// collection it belongs to. Collections are ordered by size desc,
// then alphabetically.
const collectionCounts = new Map<string, number>();
for (const nb of notebooks) {
  for (const c of nb.collections) collectionCounts.set(c, (collectionCounts.get(c) ?? 0) + 1);
}
const collectionOrder = [...collectionCounts.entries()]
  .sort((a, b) => {
    if (a[0] === "in-progress") return -1;
    if (b[0] === "in-progress") return 1;
    return b[1] - a[1] || a[0].localeCompare(b[0]);
  })
  .map(([c]) => c);
const groupedByCollection = collectionOrder.map((collection) => ({
  collection,
  notebooks: notebooks.filter((nb) => nb.collections.includes(collection)),
}));
const uncollected = notebooks.filter((nb) => nb.collections.length === 0);

const articleModules = import.meta.glob("./articles/*.mdx", { eager: true });
const articles = Object.entries(articleModules)
  .map(([path, mod]) => {
    const slug = path
      .split("/")
      .pop()
      .replace(/\.mdx$/, "");
    const fm = mod.frontmatter;
    return {
      slug,
      entry: fm.entry,
      title: String(fm.title).replace(/^\d+\s*[—–-]\s*/, ""),
      date: fm.date,
    };
  })
  .sort((a, b) => -b.entry + a.entry);

const formatDate = (raw) => {
  const d =
    raw instanceof Date
      ? raw
      : new Date(String(raw).includes("T") ? String(raw) : String(raw) + "T00:00:00Z");
  if (isNaN(d.getTime())) return String(raw);
  const day = d.getUTCDate();
  const suffix =
    day % 100 >= 11 && day % 100 <= 13
      ? "th"
      : day % 10 === 1
        ? "st"
        : day % 10 === 2
          ? "nd"
          : day % 10 === 3
            ? "rd"
            : "th";
  const month = d.toLocaleDateString("en-GB", { month: "short", timeZone: "UTC" });
  const year = d.getUTCFullYear();
  return `${day}${suffix} ${month} ${year}`;
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Pinglab</title>
  </head>
  <body>
    <aside
      class="hidden lg:block fixed top-16 left-8 w-[calc(25%-4rem)] max-h-[calc(100vh-8rem)] overflow-y-auto text-base pr-4"
      aria-label="Pages"
    >
      <p class="mb-2 text-xs uppercase tracking-wider text-[color:var(--muted)]">Documentation</p>
      <ol class="pl-0 list-none space-y-1.5">
        <li>
          <a
            href="/docs/introduction/"
            class="text-[#555] !no-underline hover:text-[color:var(--ink)] leading-snug"
            >Introduction</a
          >
        </li>
        <li>
          <a
            href="/docs/models/"
            class="text-[#555] !no-underline hover:text-[color:var(--ink)] leading-snug">Models</a
          >
        </li>
        <li>
          <a
            href="/docs/training/"
            class="text-[#555] !no-underline hover:text-[color:var(--ink)] leading-snug">Training</a
          >
        </li>
        <li>
          <a
            href="/docs/the-oscilloscope/"
            class="text-[#555] !no-underline hover:text-[color:var(--ink)] leading-snug"
            >The Oscilloscope</a
          >
        </li>
        <li>
          <a
            href="/docs/the-notebooks/"
            class="text-[#555] !no-underline hover:text-[color:var(--ink)] leading-snug"
            >The Notebooks</a
          >
        </li>
        <li>
          <a
            href="/docs/metrics/"
            class="text-[#555] !no-underline hover:text-[color:var(--ink)] leading-snug">Metrics</a
          >
        </li>
        <li>
          <a
            href="/docs/parameters-and-units/"
            class="text-[#555] !no-underline hover:text-[color:var(--ink)] leading-snug"
            >Parameters &amp; Units</a
          >
        </li>
        <li>
          <a
            href="/docs/references/"
            class="text-[#555] !no-underline hover:text-[color:var(--ink)] leading-snug"
            >References</a
          >
        </li>
        <li>
          <a
            href="/docs/styleguide/"
            class="text-[#555] !no-underline hover:text-[color:var(--ink)] leading-snug"
            >Styleguide</a
          >
        </li>
      </ol>
    </aside>

    <main class="px-6 pt-16 pb-64 lg:pl-[25%] lg:pr-16 [&_a]:no-underline! [&_a:hover]:underline!">
      <div class="max-w-[46rem]">
        <div class="flex items-baseline justify-between gap-4">
          <h1 class="text-2xl font-bold">Pinglab</h1>
          <a
            href="https://github.com/eoinmurray/pinglab"
            class="text-sm text-[color:var(--muted)] hover:text-[color:var(--ink)]"
            target="_blank"
            rel="noopener">github</a
          >
        </div>
        <p class="mt-1 text-sm text-[color:var(--muted)]">
          Exploring the PING mod for spiking neural networks
        </p>

        <p class="mt-10 text-xs uppercase tracking-wider text-[color:var(--muted)]">Notebooks</p>
        <section class="mt-2">
          <div
            class="border border-[color:var(--color-rule)] rounded-[2px] bg-[color:var(--color-paper-tint)] overflow-hidden"
          >
            <table
              class="w-full border-collapse m-0 text-[0.95rem] [&_tr:first-child>td]:border-t-0"
            >
              <tbody>
                {
                  notebooks.map((nb) => (
                    <tr class="[&>td]:px-[0.7rem] [&>td]:py-[0.4rem] [&>td]:border-t [&>td]:border-[color:var(--color-rule)] [&>td]:align-baseline">
                      <td class="w-[2.2rem] text-[color:var(--color-muted)]">
                        <a href={`/notebooks/${nb.slug}/`} class="tabular-nums">
                          {String(nb.entry).padStart(1, "0")}.
                        </a>
                      </td>
                      <td>
                        <a href={`/notebooks/${nb.slug}/`}>{nb.title}</a>
                      </td>
                      <td class="w-[8rem] whitespace-nowrap tabular-nums text-[0.85rem] text-[color:var(--muted)]">
                        {formatDate(nb.date)}
                      </td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </section>
        {
          articles.length > 0 && (
            <>
              <p class="mt-12 text-xs uppercase tracking-wider text-[color:var(--muted)]">
                Articles
              </p>
              <section class="mt-2">
                <div class="border border-[color:var(--color-rule)] rounded-[2px] bg-[color:var(--color-paper-tint)] overflow-hidden">
                  <table class="w-full border-collapse m-0 text-[0.95rem] [&_tr:first-child>td]:border-t-0">
                    <tbody>
                      {articles.map((a) => (
                        <tr class="[&>td]:px-[0.7rem] [&>td]:py-[0.4rem] [&>td]:border-t [&>td]:border-[color:var(--color-rule)] [&>td]:align-baseline">
                          <td class="w-[2.2rem] text-[color:var(--color-muted)]">
                            <a href={`/articles/${a.slug}/`} class="tabular-nums">
                              {String(a.entry).padStart(1, "0")}.
                            </a>
                          </td>
                          <td>
                            <a href={`/articles/${a.slug}/`}>{a.title}</a>
                          </td>
                          <td class="w-[8rem] whitespace-nowrap tabular-nums text-[0.85rem] text-[color:var(--muted)]">
                            {formatDate(a.date)}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </section>
            </>
          )
        }
      </div>
    </main>
  </body>
</html>
