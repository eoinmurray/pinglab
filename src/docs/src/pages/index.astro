---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import PingAsciiHero from "../components/articles/PingAsciiHero";

const notebookModules = import.meta.glob("./notebooks/*.mdx", { eager: true });
const articleModules = import.meta.glob("./articles/*.mdx", { eager: true });

type Entry = {
  slug: string;
  entry: number;
  order: number | null;
  title: string;
  date: any;
  collection: string | null;
  kind: "article" | "notebook";
};

function entryCollection(fm: any): string | null {
  if (typeof fm?.collection === "string" && fm.collection.length > 0) {
    return fm.collection;
  }
  return null;
}

// Within a collection, follow an explicit `order:` field (ascending) when
// present, else newest first by entry. Ordered entries sort ahead of others.
function byOrderThenEntry(a: Entry, b: Entry): number {
  if (a.order != null && b.order != null) return a.order - b.order;
  if (a.order != null) return -1;
  if (b.order != null) return 1;
  return b.entry - a.entry;
}

const articles: Entry[] = Object.entries(articleModules)
  .map(([path, mod]: [string, any]) => {
    const slug = path.split("/").pop()!.replace(/\.mdx$/, "");
    const fm = mod.frontmatter;
    return {
      slug,
      entry: fm.entry,
      order: typeof fm.order === "number" ? fm.order : null,
      title: String(fm.title).replace(/^\d+\s*[—–-]\s*/, ""),
      date: fm.date,
      collection: entryCollection(fm),
      kind: "article" as const,
    };
  })
  .sort(byOrderThenEntry);

const notebooks: Entry[] = Object.entries(notebookModules)
  .map(([path, mod]: [string, any]) => {
    const slug = path.split("/").pop()!.replace(/\.mdx$/, "");
    const fm = mod.frontmatter;
    return {
      slug,
      entry: fm.entry,
      order: typeof fm.order === "number" ? fm.order : null,
      title: String(fm.title).replace(/^\d+\s*[—–-]\s*/, ""),
      date: fm.date,
      collection: entryCollection(fm),
      kind: "notebook" as const,
    };
  })
  .sort(byOrderThenEntry);

// Bucket articles + notebooks by collection.
const UNCOLLECTED = "__uncollected";
type Bucket = {
  collection: string;
  label: string;
  articles: typeof articles;
  notebooks: typeof notebooks;
};
const bucketByName = new Map<string, Bucket>();
function getBucket(name: string): Bucket {
  if (!bucketByName.has(name)) {
    bucketByName.set(name, {
      collection: name,
      label:
        name === UNCOLLECTED
          ? "Misc"
          : name
              .split("-")
              .map((w) => (["cuba", "coba", "ping", "snn"].includes(w) ? w.toUpperCase() : w.charAt(0).toUpperCase() + w.slice(1)))
              .join(" "),
      articles: [],
      notebooks: [],
    });
  }
  return bucketByName.get(name)!;
}
for (const a of articles) getBucket(a.collection ?? UNCOLLECTED).articles.push(a);
for (const n of notebooks) getBucket(n.collection ?? UNCOLLECTED).notebooks.push(n);

const buckets = [...bucketByName.values()].sort((a, b) => {
  if (a.collection === "in-progress") return -1;
  if (b.collection === "in-progress") return 1;
  if (a.collection === UNCOLLECTED) return 1;
  if (b.collection === UNCOLLECTED) return -1;
  const totA = a.articles.length + a.notebooks.length;
  const totB = b.articles.length + b.notebooks.length;
  return totB - totA || a.collection.localeCompare(b.collection);
});

// future-experiments is pinned to the second slot to keep the proposal thread
// visible regardless of how few entries it has yet.
const pinnedIdx = buckets.findIndex((b) => b.collection === "future-experiments");
if (pinnedIdx > 1) {
  const [pinned] = buckets.splice(pinnedIdx, 1);
  buckets.splice(1, 0, pinned);
}

const formatDate = (raw: any) => {
  const d =
    raw instanceof Date
      ? raw
      : new Date(String(raw).includes("T") ? String(raw) : String(raw) + "T00:00:00Z");
  if (isNaN(d.getTime())) return String(raw);
  const day = d.getUTCDate();
  const suffix =
    day % 100 >= 11 && day % 100 <= 13
      ? "th"
      : day % 10 === 1
        ? "st"
        : day % 10 === 2
          ? "nd"
          : day % 10 === 3
            ? "rd"
            : "th";
  const month = d.toLocaleDateString("en-GB", { month: "short", timeZone: "UTC" });
  const year = d.getUTCFullYear();
  return `${day}${suffix} ${month} ${year}`;
};

const totalArticles = articles.length;
const totalNotebooks = notebooks.length;
const totalCollections = buckets.filter((b) => b.collection !== UNCOLLECTED).length;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Pinglab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="https://fonts.gstatic.com/s/jetbrainsmono/v24/tDbY2o-flEEny0FZhsfKu5WU4zr3E_BX0PnT8RD8L6tTOlOVk6OThhvA.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff"
      href="https://cdn.jsdelivr.net/gh/aaaakshat/cm-web-fonts@master/font/Serif/cmunrm.woff"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff"
      href="https://cdn.jsdelivr.net/gh/aaaakshat/cm-web-fonts@master/font/Serif/cmunbx.woff"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@700&display=block"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var resolved =
            stored === "light" || stored === "dark"
              ? stored
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.setAttribute("data-theme", resolved);
        } catch (e) {}
      })();
    </script>
    <style>
      .hero-overlay {
        background: linear-gradient(
          to right,
          rgba(255, 255, 255, 0.92) 0%,
          rgba(255, 255, 255, 0.78) 40%,
          rgba(255, 255, 255, 0) 85%
        );
      }
      :root[data-theme="dark"] .hero-overlay {
        background: linear-gradient(
          to right,
          rgba(21, 20, 15, 0.92) 0%,
          rgba(21, 20, 15, 0.78) 40%,
          rgba(21, 20, 15, 0) 85%
        );
      }
    </style>
  </head>
  <body>
    <div class="fixed top-4 right-4 z-40">
      <ThemeToggle />
    </div>

    <!-- Hero -->
    <section
      class="relative hero-section"
      style="height: 320px; background: var(--paper);"
    >
      <PingAsciiHero client:only="react" height="320px" borderRadius="0" margin="0" />
      <div
        class="hero-overlay absolute inset-0 flex items-center px-6 lg:pl-[25%] lg:pr-16 pointer-events-none"
      >
        <div class="max-w-[46rem] pointer-events-auto">
          <h1
            class="text-5xl md:text-6xl font-bold tracking-tight"
            style="font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace; line-height: 1; min-height: 1em;"
          >
            PINGLAB
          </h1>
          <p class="mt-3 text-base md:text-lg text-muted max-w-[34rem]">
            Open research notes on gamma-gated sparsity in conductance-based excitatory–inhibitory spiking neural networks.
          </p>
          <div class="mt-5 flex flex-wrap items-baseline gap-x-5 gap-y-2 text-sm">
            <a href="/articles/" class="text-muted hover:text-[color:var(--ink)]">
              {totalArticles} articles
            </a>
            <a href="/notebooks/" class="text-muted hover:text-[color:var(--ink)]">
              {totalNotebooks} notebooks
            </a>
            <a href="/collections/" class="text-muted hover:text-[color:var(--ink)]">
              {totalCollections} collections
            </a>
            <a
              href="https://github.com/eoinmurray/pinglab"
              class="text-muted hover:text-[color:var(--ink)]"
              target="_blank"
              rel="noopener"
            >
              github →
            </a>
          </div>
        </div>
      </div>
    </section>

    <div class="pt-10"></div>

    <main class="px-6 pb-48 lg:pl-[25%] lg:pr-16 [&_a]:no-underline! [&_a:hover]:underline!">
      <div class="max-w-[46rem] flex flex-col gap-16">

        <!-- All collections -->
        <section>
          <div class="flex flex-col gap-10">
            {
              buckets.map((bucket) => (
                <section>
                  <p class="mb-2 text-xs uppercase tracking-wider text-muted">
                    {bucket.collection === UNCOLLECTED ? (
                      bucket.label
                    ) : (
                      <a href={`/collections/${bucket.collection}/`}>{bucket.label}</a>
                    )}
                  </p>

                  {bucket.articles.length > 0 && (
                    <ol class="pl-0 list-none m-0 text-[0.95rem]">
                      {bucket.articles.map((a) => (
                        <li class="flex items-baseline gap-3 py-[0.3rem]">
                          <a
                            href={`/articles/${a.slug}/`}
                            class="shrink-0 font-mono tabular-nums text-[0.85rem] text-muted-soft"
                          >
                            {a.slug}
                          </a>
                          <a href={`/articles/${a.slug}/`} class="flex-1 min-w-0">
                            {a.title}
                          </a>
                          <span class="shrink-0 whitespace-nowrap tabular-nums text-[0.85rem] text-muted-soft">
                            {formatDate(a.date)}
                          </span>
                        </li>
                      ))}
                    </ol>
                  )}

                  {bucket.notebooks.length > 0 && (
                    <ol class="pl-0 list-none m-0 text-[0.95rem]">
                      {bucket.notebooks.map((nb) => (
                        <li class="flex items-baseline gap-3 py-[0.3rem]">
                          <a
                            href={`/notebooks/${nb.slug}/`}
                            class="shrink-0 font-mono tabular-nums text-[0.85rem] text-muted-soft"
                          >
                            {nb.slug}
                          </a>
                          <a href={`/notebooks/${nb.slug}/`} class="flex-1 min-w-0">
                            {nb.title}
                          </a>
                          <span class="shrink-0 whitespace-nowrap tabular-nums text-[0.85rem] text-muted-soft">
                            {formatDate(nb.date)}
                          </span>
                        </li>
                      ))}
                    </ol>
                  )}
                </section>
              ))
            }
          </div>
        </section>

      </div>
    </main>
  </body>
</html>
