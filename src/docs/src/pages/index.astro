---
import "../styles/global.css";
import { getCollection } from "astro:content";
import ThemeToggle from "../components/ThemeToggle.astro";
import PingAsciiHero from "../components/articles/PingAsciiHero";
import { collectionLabel, collectionDescription } from "../config/collections";

type Item = { slug: string; entry: number; title: string; kind: "articles" | "notebooks" };

const articles = (await getCollection("articles")).map((e) => ({
  slug: e.id,
  entry: e.data.entry,
  title: String(e.data.title).replace(/^\d+\s*[—–-]\s*/, ""),
  collection: e.data.collection ?? null,
  kind: "articles" as const,
}));
const notebooks = (await getCollection("notebooks")).map((e) => ({
  slug: e.id,
  entry: e.data.entry,
  title: String(e.data.title).replace(/^\d+\s*[—–-]\s*/, ""),
  collection: e.data.collection ?? null,
  kind: "notebooks" as const,
}));

type Card = {
  slug: string;
  label: string;
  description?: string;
  count: number;
  latest?: Item;
};

const cardByName = new Map<string, Card & { items: Item[] }>();
for (const e of [...articles, ...notebooks]) {
  if (!e.collection) continue;
  if (!cardByName.has(e.collection)) {
    cardByName.set(e.collection, {
      slug: e.collection,
      label: collectionLabel(e.collection),
      description: collectionDescription(e.collection),
      count: 0,
      items: [],
    });
  }
  const c = cardByName.get(e.collection)!;
  c.count++;
  c.items.push(e);
}

const cards: Card[] = [...cardByName.values()]
  .map((c) => ({ ...c, latest: [...c.items].sort((a, b) => b.entry - a.entry)[0] }))
  .sort((a, b) => b.count - a.count || a.slug.localeCompare(b.slug));

const totalArticles = articles.length;
const totalNotebooks = notebooks.length;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Pinglab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@700&display=block"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var resolved =
            stored === "light" || stored === "dark"
              ? stored
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.setAttribute("data-theme", resolved);
        } catch (e) {}
      })();
    </script>
    <style>
      .hero-overlay {
        background: linear-gradient(
          to right,
          rgba(255, 255, 255, 0) 0%,
          rgba(255, 255, 255, 0.88) 28%,
          rgba(255, 255, 255, 0.88) 72%,
          rgba(255, 255, 255, 0) 100%
        );
      }
      :root[data-theme="dark"] .hero-overlay {
        background: linear-gradient(
          to right,
          rgba(21, 20, 15, 0) 0%,
          rgba(21, 20, 15, 0.88) 28%,
          rgba(21, 20, 15, 0.88) 72%,
          rgba(21, 20, 15, 0) 100%
        );
      }
      @keyframes blink { 0%, 49% { opacity: 1 } 50%, 100% { opacity: 0 } }
      .cursor { animation: blink 1.1s steps(1) infinite; color: var(--color-cat-red); }
      .col-label { transition: color 0.14s ease; }
      .col-card:hover .col-label { color: var(--color-cat-red); }
      .col-card:hover .col-arrow { transform: translateX(3px); opacity: 1; }
      .col-arrow { transition: transform 0.16s ease, opacity 0.16s ease; opacity: 0.5; }
    </style>
  </head>
  <body>
    <div class="fixed top-4 right-4 z-40">
      <ThemeToggle />
    </div>

    <!-- Hero -->
    <section class="relative hero-section" style="height: 320px; background: var(--paper);">
      <PingAsciiHero client:only="react" height="320px" borderRadius="0" margin="0" />
      <div
        class="hero-overlay absolute inset-0 flex items-center justify-center px-6 pointer-events-none"
      >
        <div class="max-w-[46rem] w-full text-center pointer-events-auto">
          <h1
            class="text-5xl md:text-6xl font-bold tracking-tight"
            style="font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace; line-height: 1; min-height: 1em;"
          >
            PINGLAB<span class="cursor">_</span>
          </h1>
          <p class="mt-3 text-base md:text-lg text-muted max-w-[34rem] mx-auto">
            Open research notes on gamma-gated sparsity in conductance-based excitatory–inhibitory
            spiking neural networks.
          </p>
          <div class="mt-5 flex flex-wrap items-baseline justify-center gap-x-5 gap-y-2 text-sm">
            <a href="/articles/" class="text-muted hover:text-[color:var(--ink)]">
              {totalArticles} articles
            </a>
            <a href="/notebooks/" class="text-muted hover:text-[color:var(--ink)]">
              {totalNotebooks} notebooks
            </a>
            <a href="/articles/ar061/" class="text-muted hover:text-[color:var(--ink)]">feed</a>
            <a
              href="https://github.com/eoinmurray/pinglab"
              class="text-muted hover:text-[color:var(--ink)]"
              target="_blank"
              rel="noopener"
            >
              github →
            </a>
          </div>
        </div>
      </div>
    </section>

    <main class="px-6 pt-14 pb-48">
      <div class="max-w-[44rem] mx-auto text-center">
        <p class="mb-8 text-xs uppercase tracking-wider text-muted">
          Collections · {cards.length}
        </p>
        <div class="flex flex-col gap-10">
          {
            cards.map((c) => (
              <a href={`/collections/${c.slug}/`} class="col-card block no-underline!">
                <div class="flex items-baseline justify-center gap-2.5">
                  <span
                    class="col-label font-bold text-[color:var(--ink)]"
                    style="font-family: var(--font-mono);"
                  >
                    {c.label}
                  </span>
                  <span class="text-[0.72rem] tabular-nums uppercase tracking-wider text-muted-soft">
                    {c.count} {c.count === 1 ? "entry" : "entries"}
                  </span>
                </div>
                {c.description && (
                  <p class="mt-2 mx-auto max-w-[34rem] text-[0.9rem] leading-snug text-muted">
                    {c.description}
                  </p>
                )}
                {c.latest && (
                  <p class="mt-2 text-[0.78rem] text-muted-soft">
                    latest · {c.latest.slug} {c.latest.title}{" "}
                    <span class="col-arrow inline-block">→</span>
                  </p>
                )}
              </a>
            ))
          }
        </div>
      </div>
    </main>
  </body>
</html>
