---
import "../../styles/global.css";
import { getCollection } from "astro:content";
import ThemeToggle from "../../components/ThemeToggle.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { collectionLabel, collectionDescription, collectionRank } from "../../config/collections";

type Bucket = { articles: number; notebooks: number };
const buckets = new Map<string, Bucket>();

function tally(kind: "articles" | "notebooks", c: unknown) {
  if (typeof c !== "string" || c.length === 0) return;
  if (!buckets.has(c)) buckets.set(c, { articles: 0, notebooks: 0 });
  buckets.get(c)![kind]++;
}

for (const e of await getCollection("notebooks")) tally("notebooks", e.data.collection);
for (const e of await getCollection("articles")) tally("articles", e.data.collection);

// Explicit display order (config/collections.ts); unlisted slugs sort after,
// alphabetically.
const entries = [...buckets.entries()].sort(
  (a, b) => collectionRank(a[0]) - collectionRank(b[0]) || a[0].localeCompare(b[0]),
);

function countLabel(articles: number, notebooks: number): string {
  const parts: string[] = [];
  if (articles > 0) parts.push(`${articles} article${articles === 1 ? "" : "s"}`);
  if (notebooks > 0) parts.push(`${notebooks} notebook${notebooks === 1 ? "" : "s"}`);
  return parts.join(", ");
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Collections · Pinglab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var resolved =
            stored === "light" || stored === "dark"
              ? stored
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.setAttribute("data-theme", resolved);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <div class="fixed top-4 right-4 z-40">
      <ThemeToggle />
    </div>
    <header class="px-6 pt-16 lg:pl-[25%] lg:pr-16 [&_a]:no-underline! [&_a:hover]:underline!">
      <div class="max-w-[46rem]">
        <SiteHeader />
      </div>
    </header>

    <main class="px-6 pt-10 pb-48 lg:pl-[25%] lg:pr-16 [&_a]:no-underline! [&_a:hover]:underline!">
      <div class="max-w-[46rem]">
        <div class="flex flex-col gap-12">
          <section>
            <p class="mb-2 text-xs uppercase tracking-wider text-muted">Collections</p>
            {
              entries.length > 0 ? (
                <ol class="pl-0 list-none m-0 text-[0.95rem]">
                  {entries.map(([name, { articles, notebooks }]) => (
                    <li class="py-[0.5rem]">
                      <div class="flex items-baseline gap-3">
                        <a href={`/collections/${name}/`} class="flex-1 min-w-0">
                          {collectionLabel(name)}
                        </a>
                        <span class="shrink-0 whitespace-nowrap tabular-nums text-[0.85rem] text-muted-soft">
                          {countLabel(articles, notebooks)}
                        </span>
                      </div>
                      {collectionDescription(name) && (
                        <p class="mt-0.5 text-[0.85rem] leading-snug text-muted-soft">
                          {collectionDescription(name)}
                        </p>
                      )}
                    </li>
                  ))}
                </ol>
              ) : (
                <p class="text-sm text-muted">None yet.</p>
              )
            }
          </section>
        </div>
      </div>
    </main>
  </body>
</html>
