---
import "../../styles/global.css";
import { getCollection } from "astro:content";
import ThemeToggle from "../../components/ThemeToggle.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import { collectionLabel, collectionDescription } from "../../config/collections";

type Entry = {
  slug: string;
  entry: number;
  title: string;
  date: any;
  collection: string | null;
  status?: string;
};

function buildEntries(entries: any[]): Entry[] {
  return entries.map((e) => {
    const c =
      typeof e.data.collection === "string" && e.data.collection.length > 0
        ? e.data.collection
        : null;
    return {
      slug: e.id,
      entry: e.data.entry,
      title: String(e.data.title ?? e.id).replace(/^\d+\s*[—–-]\s*/, ""),
      date: e.data.date,
      collection: c,
      status: e.data.status,
    };
  });
}

// Newest first by entry id (highest id first).
function byEntryDesc(a: Entry, b: Entry): number {
  return b.entry - a.entry;
}

// Notebooks: final entries first, then newest entry id first within each status.
function byStatusThenEntry(a: Entry, b: Entry): number {
  const rank = (s?: string) => (s === "final" ? 0 : 1);
  return rank(a.status) - rank(b.status) || b.entry - a.entry;
}

export async function getStaticPaths() {
  const cs = new Set<string>();
  for (const e of await getCollection("notebooks")) {
    if (e.data.collection) cs.add(e.data.collection);
  }
  for (const e of await getCollection("articles")) {
    if (e.data.collection) cs.add(e.data.collection);
  }
  return [...cs].map((c) => ({ params: { collection: c } }));
}

const { collection } = Astro.params;
const label = collectionLabel(String(collection));
const description = collectionDescription(String(collection));

const articles = buildEntries(await getCollection("articles"))
  .filter((a) => a.collection === collection)
  .sort(byEntryDesc);

const notebooks = buildEntries(await getCollection("notebooks"))
  .filter((nb) => nb.collection === collection)
  .sort(byStatusThenEntry);

const formatDate = (raw: any) => {
  const d =
    raw instanceof Date
      ? raw
      : new Date(String(raw).includes("T") ? String(raw) : String(raw) + "T00:00:00Z");
  if (isNaN(d.getTime())) return String(raw);
  const day = d.getUTCDate();
  const suffix =
    day % 100 >= 11 && day % 100 <= 13
      ? "th"
      : day % 10 === 1
        ? "st"
        : day % 10 === 2
          ? "nd"
          : day % 10 === 3
            ? "rd"
            : "th";
  const month = d.toLocaleDateString("en-GB", { month: "short", timeZone: "UTC" });
  const year = d.getUTCFullYear();
  return `${day}${suffix} ${month} ${year}`;
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{collection} · Collections · Pinglab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var resolved =
            stored === "light" || stored === "dark"
              ? stored
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.setAttribute("data-theme", resolved);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <div class="fixed top-4 right-4 z-40">
      <ThemeToggle />
    </div>
    <header class="px-6 pt-16 lg:pl-[25%] lg:pr-16 [&_a]:no-underline! [&_a:hover]:underline!">
      <div class="max-w-[46rem]">
        <SiteHeader />
      </div>
    </header>

    <main class="px-6 pt-10 pb-48 lg:pl-[25%] lg:pr-16 [&_a]:no-underline! [&_a:hover]:underline!">
      <div class="max-w-[46rem]">
        <div class="flex flex-col gap-12">
          <div>
            <p class="text-xs uppercase tracking-wider text-muted">
              Collection / <span class="text-ink">{label}</span>
            </p>
            {description && (
              <p class="mt-2 text-[0.95rem] leading-snug text-muted-soft">{description}</p>
            )}
          </div>
          {
            articles.length > 0 && (
              <section>
                <p class="mb-2 text-xs uppercase tracking-wider text-muted">Articles</p>
                <ol class="pl-0 list-none m-0 text-[0.95rem]">
                  {articles.map((a) => (
                    <li class="flex items-baseline gap-3 py-[0.3rem]">
                      <a
                        href={`/articles/${a.slug}/`}
                        class="shrink-0 font-mono tabular-nums text-[0.85rem] text-muted-soft"
                      >
                        {a.slug}
                      </a>
                      <a href={`/articles/${a.slug}/`} class="flex-1 min-w-0">
                        {a.title}
                      </a>
                      <span class="w-20 shrink-0" />
                      <span class="w-28 shrink-0 text-right whitespace-nowrap tabular-nums text-[0.85rem] text-muted-soft">
                        {formatDate(a.date)}
                      </span>
                    </li>
                  ))}
                </ol>
              </section>
            )
          }

          {
            notebooks.length > 0 && (
              <section>
                <p class="mb-2 text-xs uppercase tracking-wider text-muted">Notebooks</p>
                <ol class="pl-0 list-none m-0 text-[0.95rem]">
                  {notebooks.map((nb) => (
                    <li class="flex items-baseline gap-3 py-[0.3rem]">
                      <a
                        href={`/notebooks/${nb.slug}/`}
                        class="shrink-0 font-mono tabular-nums text-[0.85rem] text-muted-soft"
                      >
                        {nb.slug}
                      </a>
                      <a href={`/notebooks/${nb.slug}/`} class="flex-1 min-w-0">
                        {nb.title}
                      </a>
                      <span class="w-20 shrink-0 text-right">
                        {nb.status && <StatusBadge status={nb.status} />}
                      </span>
                      <span class="w-28 shrink-0 text-right whitespace-nowrap tabular-nums text-[0.85rem] text-muted-soft">
                        {formatDate(nb.date)}
                      </span>
                    </li>
                  ))}
                </ol>
              </section>
            )
          }

          {
            articles.length === 0 && notebooks.length === 0 && (
              <p class="text-sm text-muted">No entries.</p>
            )
          }
        </div>
      </div>
    </main>
  </body>
</html>
