---
import "../styles/global.css";
import { getCollection } from "astro:content";
import SiteHeader from "../components/SiteHeader.astro";

const articles = (await getCollection("articles")).sort((a, b) => {
  const aNum = parseInt(a.id.replace(/\D+/, ""));
  const bNum = parseInt(b.id.replace(/\D+/, ""));
  return aNum - bNum;
});

const notebooks = (await getCollection("notebooks")).sort((a, b) => {
  const aNum = parseInt(a.id.replace(/\D+/, ""));
  const bNum = parseInt(b.id.replace(/\D+/, ""));
  return aNum - bNum;
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>All — Pinglab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var resolved =
            stored === "light" || stored === "dark"
              ? stored
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.setAttribute("data-theme", resolved);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="px-6 pt-16 lg:pl-[25%] lg:pr-16 [&_a]:no-underline! [&_a:hover]:underline!">
      <div class="max-w-[46rem]">
        <SiteHeader />
      </div>
    </header>

    <main class="px-6 pt-10 pb-48 lg:pl-[25%] lg:pr-16 [&_a]:no-underline! [&_a:hover]:underline!">
      <div class="max-w-[46rem]">
        <section class="mb-16">
          <p class="mb-2 text-xs uppercase tracking-wider text-muted">Articles</p>
          {
            articles.length > 0 ? (
              <ol class="pl-0 list-none m-0 text-[0.95rem] space-y-2">
                {articles.map((article) => (
                  <li>
                    <div class="flex items-baseline gap-3 justify-between">
                      <a href={`/articles/${article.id}/`} class="flex-1 min-w-0">
                        {article.data.title}
                      </a>
                      <span class="shrink-0 whitespace-nowrap text-[0.85rem] text-muted-soft">
                        {article.id}
                      </span>
                    </div>
                    {article.data.description && (
                      <p class="mt-0.5 text-[0.85rem] leading-snug text-muted-soft">
                        {article.data.description}
                      </p>
                    )}
                  </li>
                ))}
              </ol>
            ) : (
              <p class="text-sm text-muted">None yet.</p>
            )
          }
        </section>

        <section>
          <p class="mb-2 text-xs uppercase tracking-wider text-muted">Notebooks</p>
          {
            notebooks.length > 0 ? (
              <ol class="pl-0 list-none m-0 text-[0.95rem] space-y-2">
                {notebooks.map((notebook) => (
                  <li>
                    <div class="flex items-baseline gap-3 justify-between">
                      <a href={`/notebooks/${notebook.id}/`} class="flex-1 min-w-0">
                        {notebook.data.title}
                      </a>
                      <span class="shrink-0 whitespace-nowrap text-[0.85rem] text-muted-soft">
                        {notebook.id}
                      </span>
                    </div>
                    {notebook.data.description && (
                      <p class="mt-0.5 text-[0.85rem] leading-snug text-muted-soft">
                        {notebook.data.description}
                      </p>
                    )}
                  </li>
                ))}
              </ol>
            ) : (
              <p class="text-sm text-muted">None yet.</p>
            )
          }
        </section>
      </div>
    </main>
  </body>
</html>
