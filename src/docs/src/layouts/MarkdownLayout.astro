---
import "katex/dist/katex.min.css";
import "../styles/global.css";
import { blobUrl } from "../config/repo";
const { frontmatter, headings = [], file } = Astro.props as {
  frontmatter: any;
  headings?: any;
  file?: string;
};

type Heading = { depth: number; slug: string; text: string };
const toc: Heading[] = headings.filter((h: Heading) => h.depth >= 2 && h.depth <= 3);

// `file` is an absolute filesystem path to the source .md/.mdx. Strip the
// repo prefix so the "Edit on GitHub" link points at the file in-tree.
let editHref: string | null = null;
if (file) {
  const idx = file.indexOf("/src/docs/");
  if (idx !== -1) {
    const relPath = file.slice(idx + 1); // drop leading "/"
    editHref = blobUrl(relPath);
  }
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{frontmatter.title} · Pinglab</title>
  </head>
  <body>
    {toc.length > 0 && (
      <aside
        class="hidden lg:block fixed top-16 left-8 w-[calc(25%-4rem)] max-h-[calc(100vh-8rem)] overflow-y-auto text-sm pr-4"
        aria-label="Table of contents"
      >
        <ol class="pl-0 list-none space-y-1.5">
          {toc.map((h) => (
            <li class={h.depth === 3 ? "pl-4" : ""}>
              <a
                href={`#${h.slug}`}
                class="text-[#555] !no-underline hover:text-[color:var(--ink)] leading-snug"
              >
                {h.text}
              </a>
            </li>
          ))}
        </ol>
      </aside>
    )}

    <main class="px-6 pt-16 pb-48 lg:pl-[25%] lg:pr-16">
      <div class="max-w-[46rem]">
        <article class="prose max-w-none" style="font-family: var(--font-serif);">
          <slot />
        </article>
        {editHref && (
          <footer class="page-source not-prose">
            <a href={editHref} target="_blank" rel="noopener">Edit this page on GitHub →</a>
          </footer>
        )}
      </div>
    </main>
  </body>
</html>

<style>
  .page-source {
    margin-top: 3rem;
    padding-top: 0.75rem;
    border-top: 1px solid #e7e5df;
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: #777;
  }
  .page-source a {
    color: #555;
  }
</style>
