---
import "katex/dist/katex.min.css";
import katex from "katex";
import { readFileSync } from "node:fs";
import "../styles/global.css";
import { blobUrl } from "../config/repo";
import ThemeToggle from "../components/ThemeToggle.astro";
import SiteHeader from "../components/SiteHeader.astro";
import StatusBadge from "../components/StatusBadge.astro";
const { frontmatter, headings = [], file } = Astro.props as {
  frontmatter: any;
  headings?: any;
  file?: string;
};

type Heading = { depth: number; slug: string; text: string };

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

// Render `$...$` and `$$...$$` segments via KaTeX; escape the rest.
function renderTocText(text: string): string {
  const parts = text.split(/(\$\$[^$]+\$\$|\$[^$]+\$)/g);
  return parts
    .map((part) => {
      if (!part) return "";
      const display = part.startsWith("$$") && part.endsWith("$$");
      const inline = !display && part.startsWith("$") && part.endsWith("$");
      if (display || inline) {
        const expr = display ? part.slice(2, -2) : part.slice(1, -1);
        try {
          return katex.renderToString(expr, {
            displayMode: display,
            throwOnError: false,
            output: "html",
          });
        } catch {
          return escapeHtml(part);
        }
      }
      return escapeHtml(part);
    })
    .join("");
}

// Astro's `headings.text` is the rendered heading's textContent, which for
// math headings concatenates KaTeX's MathML annotation with the rendered
// glyphs (e.g. "Δt\Delta tΔt"). Re-parse the raw source so we recover the
// original `$...$` segments. Slug comes from Astro (matches the rendered
// heading id); the rendered HTML comes from the raw source.
type TocEntry = { depth: number; slug: string; html: string };

const astroHeadings: Heading[] = (headings as Heading[]).filter(
  (h) => h.depth >= 1 && h.depth <= 6,
);

let rawHeadings: { depth: number; raw: string }[] = [];
if (file) {
  try {
    const src = readFileSync(file, "utf8");
    let body = src.replace(/^---\n[\s\S]*?\n---\n?/, "");
    body = body.replace(/```[\s\S]*?```/g, "");
    for (const line of body.split(/\r?\n/)) {
      const m = /^(#{1,6})\s+(.+?)\s*$/.exec(line);
      if (m) rawHeadings.push({ depth: m[1].length, raw: m[2] });
    }
  } catch {
    rawHeadings = [];
  }
}

const useRaw = rawHeadings.length === astroHeadings.length;
const toc: TocEntry[] = astroHeadings
  .map((h, i) => ({
    depth: h.depth,
    slug: h.slug,
    html: useRaw ? renderTocText(rawHeadings[i].raw) : escapeHtml(h.text),
  }))
  .filter((h) => h.depth >= 2 && h.depth <= 3);

// `file` is an absolute filesystem path to the source .md/.mdx. Strip the
// repo prefix so the "Edit on GitHub" link points at the file in-tree.
let editHref: string | null = null;
if (file) {
  const idx = file.indexOf("/src/docs/");
  if (idx !== -1) {
    const relPath = file.slice(idx + 1); // drop leading "/"
    editHref = blobUrl(relPath);
  }
}

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{frontmatter.title} · Pinglab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var resolved =
            stored === "light" || stored === "dark"
              ? stored
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.setAttribute("data-theme", resolved);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <div class="fixed top-4 right-4 z-40">
      <ThemeToggle />
    </div>

    <header class="px-6 pt-16 lg:pl-[25%] lg:pr-16 [&_a]:no-underline! [&_a:hover]:underline!">
      <div class="max-w-[46rem]">
        <SiteHeader />
      </div>
    </header>

    {toc.length > 0 && (
      <aside
        class="hidden lg:block fixed top-32 left-8 w-[calc(25%-4rem)] max-h-[calc(100vh-10rem)] overflow-y-auto text-base pr-4"
        aria-label="Table of contents"
      >
        <ol class="pl-0 list-none space-y-1.5">
          {toc.map((h) => (
            <li class={h.depth === 3 ? "pl-4" : ""}>
              <a
                href={`#${h.slug}`}
                class="text-[color:var(--color-dim)] !no-underline hover:text-[color:var(--ink)] leading-snug"
                set:html={h.html}
              />

            </li>
          ))}
        </ol>
      </aside>
    )}

    <main class="px-6 pt-10 pb-48 lg:pl-[25%] lg:pr-16">
      <div class="max-w-[46rem]">
        <article class="prose max-w-none" style="font-family: var(--font-serif);">
          {frontmatter?.title && (
            <h1 class="entry-title">{frontmatter.title}</h1>
          )}
          {frontmatter?.status && (
            <div class="not-prose -mt-4 mb-6">
              <StatusBadge status={frontmatter.status} />
            </div>
          )}
          <slot />
        </article>
        {editHref && (
          <footer class="page-source not-prose">
            <a href={editHref} target="_blank" rel="noopener">Edit this page on GitHub →</a>
          </footer>
        )}
      </div>
    </main>
  </body>
</html>

<style>
  .entry-title {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.6rem;
    line-height: 1.25;
    margin: 0 0 1.5rem 0;
    color: var(--ink);
  }
  .page-source {
    margin-top: 3rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-rule);
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--color-muted-soft);
  }
  .page-source a {
    color: var(--color-dim);
  }
</style>
