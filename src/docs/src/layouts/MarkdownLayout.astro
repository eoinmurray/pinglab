---
import "katex/dist/katex.min.css";
import katex from "katex";
import "../styles/global.css";
import { blobUrl } from "../config/repo";
import SiteHeader from "../components/SiteHeader.astro";
import NotebookStatusBar from "../components/NotebookStatusBar.astro";
import { normalizeStatus, STATUS_META } from "../config/status";
import { collectionLabel as collectionLabelOf } from "../config/collections";
// Driven by the content-collection routes (articles|notebooks/[...id].astro):
// `frontmatter` is the entry's data, `headings` come from render(), `body` is
// the raw markdown (used to recover `$...$` in TOC headings), `kind`/`id`
// locate the source file for the entry-id prefix and the Edit-on-GitHub link.
const { frontmatter, headings = [], body = "", kind = "articles", id = "" } =
  Astro.props as {
    frontmatter: any;
    headings?: any;
    body?: string;
    kind?: "articles" | "notebooks";
    id?: string;
  };

// Pages can opt out of the table-of-contents sidebar (frontmatter
// `hideSidebar: true`); the content column is then centered rather than
// offset to clear the (absent) sidebar.
const hideSidebar = frontmatter?.hideSidebar === true;
const insetClass = hideSidebar ? "" : "lg:pl-[25%] lg:pr-16";
const wrapClass = hideSidebar ? "max-w-[46rem] mx-auto" : "max-w-[46rem]";

// Entry metadata strip shown under the title: nb-id · status · date · collection.
const idPrefix = kind === "articles" ? "ar" : "nb";
const entryId =
  frontmatter?.entry != null
    ? `${idPrefix}${String(frontmatter.entry).padStart(3, "0")}`
    : null;
const collectionLabel =
  typeof frontmatter?.collection === "string" && frontmatter.collection
    ? collectionLabelOf(frontmatter.collection)
    : null;
const dateLabel = (() => {
  const raw = frontmatter?.date;
  if (!raw) return null;
  const d =
    raw instanceof Date
      ? raw
      : new Date(
          String(raw).includes("T") ? String(raw) : String(raw) + "T00:00:00Z",
        );
  if (isNaN(d.getTime())) return String(raw);
  return d.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
    timeZone: "UTC",
  });
})();
const statusMeta = frontmatter?.status
  ? STATUS_META[normalizeStatus(frontmatter.status)]
  : null;

// Approximate prose word count from the raw markdown body: drop code, imports,
// math, and JSX/HTML tags (keeping the text inside them, e.g. captions), then
// count word-ish tokens. A reading-length cue, not an exact figure.
const wordCount = (() => {
  let t = String(body || "");
  t = t.replace(/```[\s\S]*?```/g, " "); // fenced code
  t = t.replace(/`[^`]*`/g, " "); // inline code
  t = t.replace(/^\s*(?:import|export)\b.*$/gm, " "); // import/export lines
  t = t.replace(/\$\$[\s\S]*?\$\$/g, " "); // display math
  t = t.replace(/\$[^$\n]*\$/g, " "); // inline math
  t = t.replace(/<[^>]+>/g, " "); // JSX / HTML tags (keep inner text)
  return (t.match(/[A-Za-z0-9][A-Za-z0-9'’-]*/g) || []).length;
})();

const metaItems = [
  entryId && { text: entryId },
  statusMeta && { text: statusMeta.label, title: statusMeta.description },
  dateLabel && { text: dateLabel },
  collectionLabel && {
    text: collectionLabel,
    href: `/collections/${frontmatter.collection}/`,
  },
  wordCount > 0 && { text: `${wordCount.toLocaleString("en-GB")} words` },
].filter(Boolean) as { text: string; title?: string; href?: string }[];

type Heading = { depth: number; slug: string; text: string };

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

// Render `$...$` and `$$...$$` segments via KaTeX; escape the rest.
function renderTocText(text: string): string {
  const parts = text.split(/(\$\$[^$]+\$\$|\$[^$]+\$)/g);
  return parts
    .map((part) => {
      if (!part) return "";
      const display = part.startsWith("$$") && part.endsWith("$$");
      const inline = !display && part.startsWith("$") && part.endsWith("$");
      if (display || inline) {
        const expr = display ? part.slice(2, -2) : part.slice(1, -1);
        try {
          return katex.renderToString(expr, {
            displayMode: display,
            throwOnError: false,
            output: "html",
          });
        } catch {
          return escapeHtml(part);
        }
      }
      return escapeHtml(part);
    })
    .join("");
}

// Astro's `headings.text` is the rendered heading's textContent, which for
// math headings concatenates KaTeX's MathML annotation with the rendered
// glyphs (e.g. "Δt\Delta tΔt"). Re-parse the raw source so we recover the
// original `$...$` segments. Slug comes from Astro (matches the rendered
// heading id); the rendered HTML comes from the raw source.
type TocEntry = { depth: number; slug: string; html: string };

const astroHeadings: Heading[] = (headings as Heading[]).filter(
  (h) => h.depth >= 1 && h.depth <= 6,
);

// `body` is the raw markdown (frontmatter already stripped by the content
// loader). Strip fenced code, then pull heading lines to recover their `$...$`.
let rawHeadings: { depth: number; raw: string }[] = [];
if (body) {
  const stripped = body.replace(/```[\s\S]*?```/g, "");
  for (const line of stripped.split(/\r?\n/)) {
    const m = /^(#{1,6})\s+(.+?)\s*$/.exec(line);
    if (m) rawHeadings.push({ depth: m[1].length, raw: m[2] });
  }
}

// Feed entries list one paper per H3, which would flood the TOC; show one
// level less for them (section headers only) than for normal documents.
const maxTocDepth = frontmatter?.collection === "weekly-feed" ? 2 : 3;
const useRaw = rawHeadings.length === astroHeadings.length;
const toc: TocEntry[] = astroHeadings
  .map((h, i) => ({
    depth: h.depth,
    slug: h.slug,
    html: useRaw ? renderTocText(rawHeadings[i].raw) : escapeHtml(h.text),
  }))
  .filter((h) => h.depth >= 2 && h.depth <= maxTocDepth);

// "Edit on GitHub" points at the entry's source under content/.
const editHref: string | null = id
  ? blobUrl(`src/docs/content/${kind}/${id}.mdx`)
  : null;

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{frontmatter.title} · Pinglab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var resolved =
            stored === "light" || stored === "dark"
              ? stored
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.setAttribute("data-theme", resolved);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class:list={["px-6 pt-16 [&_a]:no-underline! [&_a:hover]:underline!", insetClass]}>
      <div class:list={[wrapClass]}>
        <SiteHeader />
      </div>
    </header>

    {toc.length > 0 && !hideSidebar && (
      <aside
        class="hidden lg:block fixed top-32 left-8 w-[calc(25%-4rem)] max-h-[calc(100vh-10rem)] overflow-y-auto text-base pr-4"
        aria-label="Table of contents"
      >
        <ol class="pl-0 list-none space-y-1.5">
          {toc.map((h) => (
            <li class={h.depth === 3 ? "pl-4" : ""}>
              <a
                href={`#${h.slug}`}
                class="text-[color:var(--color-dim)] !no-underline hover:text-[color:var(--ink)] leading-snug"
                set:html={h.html}
              />

            </li>
          ))}
        </ol>
      </aside>
    )}

    <main class:list={["px-6 pt-10 pb-48", insetClass]}>
      <div class:list={[wrapClass]}>
        <article class="prose max-w-none" style="font-family: var(--font-serif);">
          {frontmatter?.title && (
            <h1 class="entry-title">{frontmatter.title}</h1>
          )}
          {metaItems.length > 0 && (
            <div class="not-prose -mt-4 mb-6 flex flex-wrap items-center gap-x-1.5 text-[0.85rem] text-muted-soft">
              {metaItems.map((m, i) => (
                <Fragment>
                  {i > 0 && <span aria-hidden="true">·</span>}
                  {m.href ? (
                    <a
                      href={m.href}
                      title={m.title}
                      class="underline-offset-2 hover:text-[color:var(--ink)] hover:underline"
                    >
                      {m.text}
                    </a>
                  ) : (
                    <span title={m.title}>{m.text}</span>
                  )}
                </Fragment>
              ))}
            </div>
          )}
          {kind === "notebooks" && id && <NotebookStatusBar slug={id} />}
          <slot />
        </article>
        {editHref && (
          <footer class="page-source not-prose">
            <a href={editHref} target="_blank" rel="noopener">Edit this page on GitHub →</a>
          </footer>
        )}
      </div>
    </main>
  </body>
</html>

<style>
  .entry-title {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.6rem;
    line-height: 1.25;
    margin: 0 0 1.5rem 0;
    color: var(--ink);
  }
  .page-source {
    margin-top: 3rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-rule);
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--color-muted-soft);
  }
  .page-source a {
    color: var(--color-dim);
  }
</style>
