---
import "katex/dist/katex.min.css";
import "../styles/global.css";
const { frontmatter, headings = [] } = Astro.props;

type Heading = { depth: number; slug: string; text: string };
const toc: Heading[] = headings.filter((h: Heading) => h.depth >= 2 && h.depth <= 3);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{frontmatter.title} · Pinglab</title>
  </head>
  <body>
    {toc.length > 0 && (
      <aside
        class="hidden lg:block fixed top-16 left-8 w-[calc(25%-4rem)] max-h-[calc(100vh-8rem)] overflow-y-auto text-sm pr-4"
        aria-label="Table of contents"
      >
        <ol class="pl-0 list-none space-y-1.5">
          {toc.map((h) => (
            <li class={h.depth === 3 ? "pl-4" : ""}>
              <a
                href={`#${h.slug}`}
                class="text-[#555] !no-underline hover:text-[color:var(--ink)] leading-snug"
              >
                {h.text}
              </a>
            </li>
          ))}
        </ol>
      </aside>
    )}

    <main class="px-6 pt-16 pb-48 lg:pl-[25%] lg:pr-16">
      <div class="max-w-[46rem]">
        <div class="flex items-baseline justify-between gap-4 text-sm text-[color:var(--muted)]">
          <a href="/">Pinglab</a>
          <a
            href="https://github.com/eoinmurray/pinglab"
            class="hover:text-[color:var(--ink)]"
            target="_blank"
            rel="noopener"
          >github</a>
        </div>

        <article class="prose max-w-none mt-8" style="font-family: var(--font-serif);">
          <slot />
        </article>
      </div>
    </main>
  </body>
</html>
