---
// A small callout banner at the top of an entry — e.g. linking a notebook to
// the shared training entry whose cells it reuses. Content goes in the slot.
---
<aside class="not-prose my-4 flex items-start gap-2 rounded-[2px] border border-rule-warm bg-paper-tint px-4 py-3 font-serif text-[0.9rem] leading-snug text-ink-soft">
  <span aria-hidden="true" class="mt-[0.1rem] shrink-0 font-bold text-[color:var(--color-cat-red)]">▸</span>
  <div class="[&_a]:underline [&_a]:decoration-1 [&_a]:underline-offset-2"><slot /></div>
</aside>
