---
// Site-wide navigation header. PINGLAB on top (H1 on the home page, otherwise
// a link back home), then global links on a row below it.
interface Props {
  isHome?: boolean;
}
const { isHome = false } = Astro.props as Props;
const pinglabClass = "text-2xl font-bold";
const pinglabStyle =
  "font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;";
const linkClass = "text-sm text-muted hover:text-[color:var(--ink)]";
---
<div>
  {isHome ? (
    <h1 class={pinglabClass} style={pinglabStyle}>PINGLAB</h1>
  ) : (
    <a href="/" class={pinglabClass} style={pinglabStyle}>PINGLAB</a>
  )}
  <nav class="mt-2 flex flex-wrap items-baseline gap-x-4 gap-y-1">
    <a href="/articles/" class={linkClass}>articles</a>
    <a href="/notebooks/" class={linkClass}>notebooks</a>
    <a href="/collections/" class={linkClass}>collections</a>
    <a href="/articles/ar061/" class={linkClass}>feed</a>
    <a
      href="https://github.com/eoinmurray/pinglab"
      class={linkClass}
      target="_blank"
      rel="noopener">github</a
    >
  </nav>
</div>
