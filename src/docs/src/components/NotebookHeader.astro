---
import { commitUrl, isDirty, shortSha } from "../config/repo";

interface Props {
  frontmatter: {
    title: string;
    date: string | Date;
    entry: number;
  };
  numbers: any;
}

const { frontmatter, numbers = {} } = Astro.props as Props;

const slug = "nb" + String(frontmatter.entry).padStart(3, "0");

// Accept either a Date (Astro often parses frontmatter YAML dates) or an ISO string.
function toDate(v: string | Date): Date | null {
  if (v instanceof Date) return isNaN(v.getTime()) ? null : v;
  if (typeof v === "string") {
    const d = new Date(v.includes("T") ? v : v + "T00:00:00Z");
    return isNaN(d.getTime()) ? null : d;
  }
  return null;
}

function formatDate(v: string | Date): string {
  const d = toDate(v);
  if (!d) return "";
  const weekday = d.toLocaleDateString("en-GB", { weekday: "long", timeZone: "UTC" });
  const day = d.getUTCDate();
  const month = d.toLocaleDateString("en-GB", { month: "long", timeZone: "UTC" });
  const yy = String(d.getUTCFullYear()).slice(-2);
  const suffix = (n: number) =>
    n % 100 >= 11 && n % 100 <= 13 ? "th" :
    n % 10 === 1 ? "st" : n % 10 === 2 ? "nd" : n % 10 === 3 ? "rd" : "th";
  return `${weekday}, ${day}${suffix(day)} ${month} ${yy}`;
}

const cfg = numbers.config ?? {};
const cells = numbers.cells ?? null;
const headlineCell = cells ? (Object.values(cells)[0] as any) ?? {} : {};
const isTraining = cells !== null;

const entryName = frontmatter.title.replace(/^\d+\s*—\s*/, "");
const dateStr = formatDate(frontmatter.date);

const sha = numbers.git_sha ?? null;
const runId = numbers.notebook_run_id ?? null;
const dirty = isDirty(sha);
const short = shortSha(sha);
const commitHref = sha ? commitUrl(sha) : null;

type Stat = { label: string; value: any; mono?: boolean };
const stats: Stat[] = [];
const tier = numbers.tier ?? cfg.tier;
if (tier) stats.push({ label: "tier", value: tier });
if (isTraining) {
  if (cfg.max_samples != null && cfg.epochs != null) {
    stats.push({ label: "samples × epochs", value: `${cfg.max_samples} × ${cfg.epochs}` });
  }
  if (headlineCell.best_acc != null) {
    stats.push({ label: "best", value: `${headlineCell.best_acc}%` });
  }
  if (headlineCell.final_acc != null) {
    stats.push({ label: "final", value: `${headlineCell.final_acc}%` });
  }
}
if (numbers.duration) stats.push({ label: "duration", value: numbers.duration });
if (runId) stats.push({ label: "run", value: runId, mono: true });
---

<header class="nb-header not-prose">
  <div class="nb-meta-top">
    <span class="nb-slug">{slug}</span>
    {dateStr && (
      <>
        <span class="nb-sep">·</span>
        <span class="nb-date">{dateStr}</span>
      </>
    )}
  </div>

  <h1 class="nb-title">{entryName}</h1>

  {stats.length > 0 && (
    <dl class="nb-stats">
      {stats.map((s) => (
        <div class="nb-stat">
          <dt>{s.label}</dt>
          <dd class={s.mono ? "mono" : ""}>{s.value}</dd>
        </div>
      ))}
      {short && (
        <div class="nb-stat">
          <dt>commit</dt>
          <dd class="mono">
            {commitHref ? (
              <a href={commitHref} target="_blank" rel="noopener">{short}</a>
            ) : (
              <span>{short}</span>
            )}
            {dirty && <span class="nb-dirty" title="figures generated from uncommitted changes">(dirty)</span>}
          </dd>
        </div>
      )}
    </dl>
  )}
</header>

<style>
  .nb-header {
    margin: 0 0 2rem;
    font-family: var(--font-serif);
  }
  .nb-meta-top {
    font-size: 0.85rem;
    color: #777;
    margin-bottom: 0.4rem;
    display: flex;
    gap: 0.4rem;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .nb-slug {
    font-family: var(--font-mono, ui-monospace, Menlo, monospace);
    color: #555;
  }
  .nb-sep {
    color: #bbb;
  }
  .nb-title {
    margin: 0 0 1rem;
    font-size: 2rem;
    line-height: 1.15;
    font-weight: 700;
    color: var(--ink, #1a1a1a);
  }
  .nb-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0 1.5rem;
    margin: 0;
    padding: 0.7rem 0.9rem;
    border-top: 1px solid #e7e5df;
    border-bottom: 1px solid #e7e5df;
    background: #fafaf7;
  }
  .nb-stat {
    display: flex;
    flex-direction: column;
    padding: 0.15rem 0;
    min-width: 0;
  }
  .nb-stat dt {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #888;
    margin: 0 0 0.1rem;
    font-weight: 500;
  }
  .nb-stat dd {
    margin: 0;
    font-size: 0.95rem;
    color: #1a1a1a;
    font-weight: 500;
  }
  .nb-stat dd.mono,
  .nb-stat dd .mono,
  .nb-stat dd a {
    font-family: var(--font-mono, ui-monospace, Menlo, monospace);
    font-size: 0.85rem;
  }
  .nb-stat dd a {
    color: #1a1a1a;
    text-decoration: underline;
    text-decoration-color: #ccc;
  }
  .nb-dirty {
    color: #a33;
    margin-left: 0.3rem;
    font-size: 0.78rem;
    font-family: var(--font-serif);
  }
</style>
