---
import { blobUrl, commitUrl, isDirty, shortSha } from "../config/repo";

interface Props {
  frontmatter: {
    title: string;
    date: string | Date;
    entry: number;
  };
  numbers: any;
}

const { frontmatter, numbers = {} } = Astro.props as Props;

const slug = "nb" + String(frontmatter.entry).padStart(3, "0");

function toDate(v: string | Date): Date | null {
  if (v instanceof Date) return isNaN(v.getTime()) ? null : v;
  if (typeof v === "string") {
    const d = new Date(v.includes("T") ? v : v + "T00:00:00Z");
    return isNaN(d.getTime()) ? null : d;
  }
  return null;
}

function formatDate(v: string | Date): string {
  const d = toDate(v);
  if (!d) return "";
  const weekday = d.toLocaleDateString("en-GB", { weekday: "long", timeZone: "UTC" });
  const day = d.getUTCDate();
  const month = d.toLocaleDateString("en-GB", { month: "long", timeZone: "UTC" });
  const yy = String(d.getUTCFullYear()).slice(-2);
  const suffix = (n: number) =>
    n % 100 >= 11 && n % 100 <= 13 ? "th" :
    n % 10 === 1 ? "st" : n % 10 === 2 ? "nd" : n % 10 === 3 ? "rd" : "th";
  return `${weekday}, ${day}${suffix(day)} ${month} ${yy}`;
}

const cfg = numbers.config ?? {};
const cells = numbers.cells ?? null;
const headlineCell = cells ? (Object.values(cells)[0] as any) ?? {} : {};
const isTraining = cells !== null;

const entryName = frontmatter.title.replace(/^\d+\s*—\s*/, "");
const dateStr = formatDate(frontmatter.date);

const sha = numbers.git_sha ?? null;
const runId = numbers.notebook_run_id ?? null;
const dirty = isDirty(sha);
const short = shortSha(sha);
const commitHref = sha ? commitUrl(sha) : null;
const runnerPath = `src/pinglab/notebooks/${slug}.py`;
const runnerHref = blobUrl(runnerPath, sha ? { sha } : {});

const criteria = Array.isArray(numbers.success_criteria) ? numbers.success_criteria : [];
const criteriaTotal = criteria.length;
const criteriaPassed = criteria.filter((c: any) => c && c.passed).length;
const criteriaFailed = criteriaTotal - criteriaPassed;
const hasGate = criteriaTotal > 0;
const allPass = hasGate && criteriaFailed === 0;

type Stat = { label: string; value: any; mono?: boolean };
const stats: Stat[] = [];
const tier = numbers.tier ?? cfg.tier;
if (tier) stats.push({ label: "tier", value: tier });
if (isTraining) {
  if (cfg.max_samples != null && cfg.epochs != null) {
    stats.push({ label: "samples × epochs", value: `${cfg.max_samples} × ${cfg.epochs}` });
  }
  if (headlineCell.best_acc != null) {
    stats.push({ label: "best", value: `${headlineCell.best_acc}%` });
  }
  if (headlineCell.final_acc != null) {
    stats.push({ label: "final", value: `${headlineCell.final_acc}%` });
  }
}
if (numbers.duration) stats.push({ label: "duration", value: numbers.duration });
if (runId) stats.push({ label: "run", value: runId, mono: true });

const ddMono = "font-mono text-[0.85rem]";
---

<header class="not-prose mb-8 font-serif">
  <div class="mb-[0.4rem] flex flex-wrap items-baseline gap-[0.4rem] text-[0.85rem] text-muted-soft">
    <span class="font-mono text-dim">{slug}</span>
    {dateStr && (
      <>
        <span class="text-faint">·</span>
        <span>{dateStr}</span>
      </>
    )}
    {hasGate && (
      <>
        <span class="text-faint">·</span>
        <a
          href="#success-criteria"
          class={`inline-flex items-baseline gap-[0.3rem] rounded-[2px] px-[0.4rem] py-[0.05rem] font-mono text-[0.72rem] font-medium uppercase tracking-wider no-underline! ${allPass ? "bg-success/10 text-success" : "bg-danger/10 text-danger"}`}
          title={`${criteriaPassed}/${criteriaTotal} success criteria passed`}
        >
          <span>{allPass ? "pass" : "fail"}</span>
          <span class="text-[0.7rem] opacity-70">{criteriaPassed}/{criteriaTotal}</span>
        </a>
      </>
    )}
  </div>

  <h1 class="mb-4 text-[2rem] font-bold leading-[1.15] text-ink-strong">{entryName}</h1>

  <dl class="m-0 flex flex-wrap gap-x-6 gap-y-0 border rounded-[2px] border-rule bg-paper-tint px-[0.9rem] py-[0.7rem]">
    {stats.length === 0 && !short && (
      <div class="flex min-w-0 flex-col py-[0.15rem]">
        <dt class="mb-[0.1rem] text-[0.72rem] font-medium uppercase tracking-wider text-label">status</dt>
        <dd class="m-0 text-[0.95rem] font-medium italic text-muted-soft">no run yet</dd>
      </div>
    )}
    {stats.map((s) => (
      <div class="flex min-w-0 flex-col py-[0.15rem]">
        <dt class="mb-[0.1rem] text-[0.72rem] font-medium uppercase tracking-wider text-label">{s.label}</dt>
        <dd class={`m-0 text-[0.95rem] font-medium text-ink-strong ${s.mono ? ddMono : ""}`}>{s.value}</dd>
      </div>
    ))}
    {short && (
      <div class="flex min-w-0 flex-col py-[0.15rem]">
        <dt class="mb-[0.1rem] text-[0.72rem] font-medium uppercase tracking-wider text-label">commit</dt>
        <dd class={`m-0 text-[0.95rem] font-medium text-ink-strong ${ddMono}`}>
          {commitHref ? (
            <a href={commitHref} class="text-ink-strong underline decoration-underline" target="_blank" rel="noopener">{short}</a>
          ) : (
            <span>{short}</span>
          )}
          {dirty && <span class="ml-[0.3rem] font-serif text-[0.78rem] text-danger" title="figures generated from uncommitted changes">(dirty)</span>}
        </dd>
      </div>
    )}
    <div class="flex min-w-0 flex-col py-[0.15rem]">
      <dt class="mb-[0.1rem] text-[0.72rem] font-medium uppercase tracking-wider text-label">runner</dt>
      <dd class={`m-0 text-[0.95rem] font-medium text-ink-strong ${ddMono}`}>
        <a
          href={runnerHref}
          class="text-ink-strong underline decoration-underline"
          target="_blank"
          rel="noopener"
          title={sha ? `${runnerPath} @ ${short}` : `${runnerPath} @ main`}
        >{slug}.py</a>
      </dd>
    </div>
  </dl>
</header>
