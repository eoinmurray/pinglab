---
/**
 * Progressive-enhancement section cross-references.
 *
 * Drop `<SectionRefs />` once anywhere in an entry. On load it builds a map
 * from section number → heading anchor (reading the `N.` / `N.M` prefix off
 * each h2/h3), then turns every inline `§N` / `§N.M` marker in the prose into
 * a link to that heading. Ranges like `§2.4–§2.6` get one link per number.
 *
 * No data or props: the headings are the source of truth. It skips math
 * (`.katex`), code, links, and headings themselves. Without JS the plain `§N`
 * text stays readable.
 */
---

<script is:inline>
  (function () {
    const article = document.querySelector("article.prose") || document.body;

    // section number ("2", "2.1", "6") → heading id
    const byNum = new Map();
    article.querySelectorAll("h1,h2,h3,h4").forEach((h) => {
      if (!h.id) return;
      const m = /^\s*(\d+(?:\.\d+)?)[.)]?\s/.exec(h.textContent || "");
      if (m && !byNum.has(m[1])) byNum.set(m[1], h.id);
    });
    if (!byNum.size) return;

    const skip = (node) => {
      let p = node.parentElement;
      while (p && p !== article) {
        const tag = p.tagName;
        const cls = typeof p.className === "string" ? p.className : "";
        if (
          tag === "A" ||
          tag === "CODE" ||
          tag === "PRE" ||
          /^H[1-6]$/.test(tag) ||
          cls.indexOf("katex") !== -1
        )
          return true;
        p = p.parentElement;
      }
      return false;
    };

    const walker = document.createTreeWalker(article, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        if (!node.nodeValue || node.nodeValue.indexOf("§") === -1)
          return NodeFilter.FILTER_REJECT;
        return skip(node) ? NodeFilter.FILTER_REJECT : NodeFilter.FILTER_ACCEPT;
      },
    });
    const targets = [];
    let cur;
    while ((cur = walker.nextNode())) targets.push(cur);

    // § followed by a section number
    const re = /§\s*(\d+(?:\.\d+)?)/g;

    targets.forEach((node) => {
      const text = node.nodeValue;
      re.lastIndex = 0;
      if (!re.test(text)) return;
      re.lastIndex = 0;
      const frag = document.createDocumentFragment();
      let last = 0;
      let m;
      while ((m = re.exec(text))) {
        frag.appendChild(document.createTextNode(text.slice(last, m.index)));
        const id = byNum.get(m[1]);
        if (id) {
          const a = document.createElement("a");
          a.className = "secref";
          a.href = "#" + id;
          a.textContent = m[0];
          frag.appendChild(a);
        } else {
          frag.appendChild(document.createTextNode(m[0]));
        }
        last = m.index + m[0].length;
      }
      frag.appendChild(document.createTextNode(text.slice(last)));
      node.parentNode.replaceChild(frag, node);
    });
  })();
</script>

<style is:global>
  .secref {
    color: var(--color-dim);
    text-decoration: underline;
    text-underline-offset: 2px;
    white-space: nowrap;
  }
  .secref:hover {
    color: var(--color-ink);
  }
</style>
