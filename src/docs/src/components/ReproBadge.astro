---
import { commitUrl, isDirty, shortSha } from "../config/repo";

interface Props {
  sha?: string | null;
  runId?: string | null;
  finished?: string | null;
}

const { sha, runId, finished } = Astro.props as Props;
const dirty = isDirty(sha);
const short = shortSha(sha);
const href = sha ? commitUrl(sha) : null;

const kv = "inline-flex items-baseline gap-1";
const k = "text-muted-soft";
const v = "text-ink";
const hasAny = Boolean(runId || short || finished);
---

<aside class="not-prose mt-3 mb-5 flex flex-wrap items-baseline gap-x-2 gap-y-1.5 rounded-[2px] border border-rule-warm bg-paper-tint px-[0.7rem] py-[0.45rem] font-serif text-[0.85rem] text-dim">
  <span class="font-semibold tracking-wide text-ink-soft">Reproduction</span>

  {!hasAny && (
    <>
      <span class="text-faint">·</span>
      <span class="italic text-muted-soft">no run yet</span>
    </>
  )}

  {runId && (
    <>
      <span class="text-faint">·</span>
      <span class={kv}><span class={k}>run</span><span class={v}>{runId}</span></span>
    </>
  )}

  {short && (
    <>
      <span class="text-faint">·</span>
      <span class={kv}>
        <span class={k}>commit</span>
        {href ? (
          <a class={`${v} font-mono`} href={href} target="_blank" rel="noopener">{short}</a>
        ) : (
          <span class={`${v} font-mono`}>{short}</span>
        )}
        {dirty && (
          <span class="ml-[0.3rem] text-[0.8em] text-danger" title="figures generated from uncommitted changes">(dirty)</span>
        )}
      </span>
    </>
  )}

  {finished && (
    <>
      <span class="text-faint">·</span>
      <span class={kv}><span class={k}>finished</span><span class={v}>{finished}</span></span>
    </>
  )}
</aside>
