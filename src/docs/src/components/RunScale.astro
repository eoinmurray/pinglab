---
/**
 * Methods run-scale table — the canonical compute-scale parameters of a run,
 * rendered from the run manifest (public/figures/notebooks/<slug>/_manifest.json)
 * that run_dirs.prepare stamps at launch, plus the elapsed time from the
 * sibling numbers.json (only known at run-end). Single source of truth: the
 * mdx never restates these numbers by hand.
 *
 * The row set is fixed and deliberately narrow — it is the terms of the cost
 * relation C ∝ N_samples · E · (T/Δt) · H, the grid multiplier, and the
 * measured elapsed. A row renders only when its field is present, so a
 * free-running sim (no training budget) omits the samples/epochs/batch/hidden
 * rows instead of printing blanks. This is NOT a general facts table — recipe
 * details (optimiser, readout, learning rate) belong in RunParameters or the
 * prose Method, not here.
 */
interface Row {
  label: string;
  value: unknown;
}
interface Props {
  manifest?: any;
  numbers?: any;
}
const { manifest = {}, numbers = {} } = Astro.props as Props;
const s = manifest?.scale ?? {};

const suffixed = (v: unknown, suffix = ""): unknown =>
  v == null ? null : `${v}${suffix}`;

const samplesEpochs =
  s.max_samples != null && s.epochs != null
    ? `${s.max_samples} × ${s.epochs}`
    : null;
// `cells` is the integer count; `grid` is a human description of the axes.
// Prefer "N (grid)", but fall back to either alone so a runner that declares
// only one still renders a row.
const gridStr = s.grid != null ? String(s.grid) : null;
const cells =
  s.cells != null
    ? `${s.cells}${gridStr ? ` (${gridStr})` : ""}`
    : gridStr;

const rows: Row[] = [
  { label: s.dataset ? "Dataset" : "Input", value: s.dataset ?? s.input ?? null },
  { label: "Training samples × epochs", value: samplesEpochs },
  { label: "Trial length T", value: suffixed(s.t_ms, " ms") },
  { label: "Timestep Δt", value: suffixed(s.dt_ms, " ms") },
  { label: "Input rate", value: suffixed(s.input_rate_hz, " Hz") },
  { label: "Hidden width", value: s.hidden ?? null },
  { label: "Batch size", value: s.batch_size ?? null },
  { label: "Seeds", value: s.seeds ?? null },
  { label: s.cells != null ? "Grid cells" : "Grid", value: cells },
  { label: "Elapsed", value: numbers?.duration ?? null },
].filter((r) => r.value != null);
---

<table>
  <thead>
    <tr>
      <th>Parameter</th>
      <th>Value</th>
    </tr>
  </thead>
  <tbody>
    {rows.map((r) => (
      <tr>
        <td>{r.label}</td>
        <td>{String(r.value)}</td>
      </tr>
    ))}
  </tbody>
</table>
