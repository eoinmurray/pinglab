---
const {
  src,
  alt = "",
  type = "image",
  id,
  title,
  controls = true,
  loop = true,
  muted = true,
  playsinline = true,
} = Astro.props;

const anchor = id ? `fig-${String(id).toLowerCase().replace(/\s+/g, "-")}` : undefined;
const hasMedia = typeof src === "string" && src.length > 0;
---

<figure class="not-prose mx-auto my-4 w-full rounded-[2px] border border-rule-warm bg-paper-tint px-4 pt-[0.85rem] pb-[0.9rem]" id={anchor}>
  {(id || title) && (
    <div class="mb-2 font-serif text-[0.95rem] leading-snug text-ink">
      {id && <span class="mr-[0.35rem] font-bold">{id}.</span>}
      {title && <span class="font-bold">{title}</span>}
    </div>
  )}
  {hasMedia ? (
    type === "video" ? (
      <video
        src={src}
        controls={controls}
        loop={loop}
        muted={muted}
        playsinline={playsinline}
        class="mb-[0.8rem] block h-auto w-full rounded-[1px] border border-rule bg-paper"
      />
    ) : (
      <img
        src={src}
        alt={alt}
        data-figure-zoom
        class="mb-[0.8rem] block h-auto w-full cursor-zoom-in rounded-[1px] border border-rule bg-paper"
      />
    )
  ) : (
    <div
      role="img"
      aria-label={alt || "No figure yet"}
      class="mb-[0.8rem] flex aspect-[16/9] w-full items-center justify-center rounded-[1px] border border-dashed border-rule bg-paper font-serif text-[0.9rem] italic text-muted-soft"
    >
      No figure yet — run the notebook to generate.
    </div>
  )}
  <figcaption class="figure-caption text-left font-serif text-[0.88rem] leading-[1.55] text-ink-soft"><slot /></figcaption>
</figure>

<style>
  .figure-caption :global(p) {
    margin: 0;
  }
  .figure-caption :global(p + p) {
    margin-top: 0.45rem;
  }
  .figure-caption :global(a) {
    color: inherit;
    text-decoration-thickness: 1px;
  }
</style>

<script>
  // Lightbox: click any img marked [data-figure-zoom] to expand to a full-
  // viewport overlay; click the backdrop (or press Escape) to close. Image
  // itself is also clickable to dismiss. One overlay element is created lazily
  // on first use and reused across all figure clicks. Idempotent — safe to
  // re-run on view transitions.
  (() => {
    if ((window as any).__figureZoomBound) return;
    (window as any).__figureZoomBound = true;

    const overlay = document.createElement("div");
    overlay.style.cssText = [
      "position:fixed",
      "inset:0",
      "background:rgba(0,0,0,0.85)",
      "display:none",
      "align-items:center",
      "justify-content:center",
      "z-index:9999",
      "cursor:zoom-out",
      "padding:2vmin",
    ].join(";");
    const big = document.createElement("img");
    big.style.cssText = [
      "max-width:100%",
      "max-height:100%",
      "object-fit:contain",
      "box-shadow:0 4px 24px rgba(0,0,0,0.4)",
    ].join(";");
    overlay.appendChild(big);
    document.body.appendChild(overlay);

    const close = () => {
      overlay.style.display = "none";
      big.src = "";
      document.body.style.overflow = "";
    };
    overlay.addEventListener("click", close);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && overlay.style.display === "flex") close();
    });

    document.addEventListener("click", (e) => {
      const t = e.target as HTMLElement;
      if (t && t.tagName === "IMG" && t.hasAttribute("data-figure-zoom")) {
        big.src = (t as HTMLImageElement).src;
        big.alt = (t as HTMLImageElement).alt;
        overlay.style.display = "flex";
        document.body.style.overflow = "hidden";
      }
    });
  })();
</script>
