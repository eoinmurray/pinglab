---
const {
  src,
  alt = "",
  type = "image",
  id,
  title,
  controls = true,
  loop = true,
  muted = true,
  playsinline = true,
} = Astro.props;

const anchor = id ? `fig-${String(id).toLowerCase().replace(/\s+/g, "-")}` : undefined;
---

<figure class="not-prose mx-auto my-4 w-full rounded-[2px] border border-rule-warm bg-paper-tint px-4 pt-[0.85rem] pb-[0.9rem]" id={anchor}>
  {(id || title) && (
    <div class="mb-2 font-serif text-[0.95rem] leading-snug text-ink">
      {id && <span class="mr-[0.35rem] font-bold">{id}.</span>}
      {title && <span class="font-bold">{title}</span>}
    </div>
  )}
  {type === "video" ? (
    <video
      src={src}
      controls={controls}
      loop={loop}
      muted={muted}
      playsinline={playsinline}
      class="mb-[0.8rem] block h-auto w-full rounded-[1px] border border-rule bg-paper"
    />
  ) : (
    <img src={src} alt={alt} class="mb-[0.8rem] block h-auto w-full rounded-[1px] border border-rule bg-paper" />
  )}
  <figcaption class="figure-caption text-left font-serif text-[0.88rem] leading-[1.55] text-ink-soft"><slot /></figcaption>
</figure>

<style>
  .figure-caption :global(p) {
    margin: 0;
  }
  .figure-caption :global(p + p) {
    margin-top: 0.45rem;
  }
  .figure-caption :global(a) {
    color: inherit;
    text-decoration-thickness: 1px;
  }
</style>
