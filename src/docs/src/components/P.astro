---
// Paragraph wrapper for manuscript-review mode.
// Usage: <P id="1.1" status="draft">Paragraph text …</P>
//
// Renders a compact status marker in the left margin (paragraph ID + a
// coloured dot). No border on the paragraph itself. The marker is
// absolutely positioned so it does not disrupt the prose flow, and
// collapses above the paragraph on narrow viewports.
//
// Status values: draft (amber) | revising (cyan) | final (green).
// Anything unrecognised falls back to muted grey.
//
// To strip before submission: search-and-replace
//   <P id="..." status="...">   →   (empty)
//   </P>                        →   (empty)
// The paragraphs collapse back to plain MDX prose.

export interface Props {
  id?: string;
  status?: string;
}

const { id, status = "draft" } = Astro.props as Props;

const STATUS_COLOUR: Record<string, string> = {
  draft: "#c8102e",     // red — signal red from the paper theme
  revising: "#e89400",  // orange / amber
  final: "#3a8a3a",     // green
};
const colour = STATUS_COLOUR[status] ?? "#999";
const label = id ?? "";
// Anchor id so a URL can point at one paragraph (…/ar009/#p-1.1).
const anchor = id ? `p-${String(id).trim().replace(/\s+/g, "-")}` : undefined;
---

<p class="review-p" id={anchor} data-review-id={id} data-review-status={status}>
  <span
    class="review-marker"
    style={`color: ${colour};`}
    title={anchor ? `§${label} — ${status} · click to copy link` : `§${label} — ${status}`}
  >
    {anchor ? (
      <a class="review-line review-anchor" href={`#${anchor}`} data-para-anchor>
        <span class="review-dot" aria-hidden="true">●</span>
        <span class="review-id">{label}</span>
      </a>
    ) : (
      <span class="review-line">
        <span class="review-dot" aria-hidden="true">●</span>
        <span class="review-id">{label}</span>
      </span>
    )}
    <span class="review-status">{status}</span>
  </span>
  <slot />
</p>

<style>
  .review-p {
    position: relative;
    scroll-margin-top: 1.5rem;
  }

  /* The id marker is a link to this paragraph's anchor. */
  a.review-anchor {
    color: inherit;
    text-decoration: none;
    cursor: pointer;
  }
  a.review-anchor:hover {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  /* Brief "copied" confirmation, driven by the script. */
  .review-marker[data-copied] .review-status {
    display: none;
  }
  .review-marker[data-copied]::after {
    content: "copied ✓";
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.85;
  }
  /* Flag the paragraph a URL pointed at. */
  .review-p:target .review-marker {
    opacity: 1;
  }

  .review-marker {
    position: absolute;
    right: -4.5rem;
    top: 0.35em;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    letter-spacing: -0.02em;
    opacity: 0.62;
    user-select: none;
    white-space: nowrap;
  }

  .review-line {
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
    font-size: 0.72rem;
  }

  .review-dot {
    font-size: 0.55rem;
    line-height: 1;
  }

  .review-id {
    color: inherit;
    opacity: 0.85;
  }

  .review-status {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.7;
  }

  /* On narrow viewports collapse the margin marker above the paragraph. */
  @media (max-width: 960px) {
    .review-marker {
      position: static;
      flex-direction: row;
      align-items: baseline;
      gap: 0.4rem;
      margin-right: 0.4rem;
      margin-bottom: 0.2rem;
      opacity: 0.5;
    }
  }
</style>

<script>
  // Clicking a paragraph marker jumps to its anchor (native <a href="#…">) and
  // copies the shareable URL to the clipboard, with a brief "copied ✓" flash.
  // Delegated + idempotent, so it covers every <P> and survives view transitions.
  (() => {
    if ((window as any).__paraAnchorBound) return;
    (window as any).__paraAnchorBound = true;
    document.addEventListener("click", (e) => {
      const link = (e.target as HTMLElement)?.closest?.(
        "a[data-para-anchor]",
      ) as HTMLAnchorElement | null;
      if (!link) return;
      const href = link.getAttribute("href") || "";
      const url = location.origin + location.pathname + location.search + href;
      navigator.clipboard?.writeText(url).then(() => {
        const marker = link.closest(".review-marker") as HTMLElement | null;
        if (!marker) return;
        marker.dataset.copied = "1";
        setTimeout(() => delete marker.dataset.copied, 1200);
      });
      // let the native anchor set the hash + scroll (don't preventDefault)
    });
  })();
</script>
