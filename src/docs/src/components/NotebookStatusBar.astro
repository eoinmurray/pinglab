---
/**
 * Per-notebook run status bar: last run date, the commit the run was locked
 * to, and a freshness pip computed at build time (helpers/staleness.ts) by
 * diffing that commit against HEAD over the code the run depended on.
 *
 * Mounted automatically for notebook entries by MarkdownLayout — no per-mdx
 * wiring. Renders nothing for an entry that has never been run and has no
 * committed figures (provenance state "unknown" with no date), so a brand-new
 * stub stays clean.
 */
import { blobUrl, commitUrl } from "../config/repo";
import { provenance, type Provenance, type RunState } from "../config/staleness";

const { slug } = Astro.props as { slug: string };
const p = provenance(slug);

function fmtDate(iso?: string): string | null {
  if (!iso) return null;
  const d = new Date(iso);
  if (isNaN(d.getTime())) return null;
  return d.toLocaleString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit",
    hour12: false,
    timeZone: "UTC",
  }).replace(",", "") + " UTC";
}

const STATE_META: Record<
  RunState,
  { color: string; label: (pv: Provenance) => string; title: string }
> = {
  fresh: {
    color: "var(--color-success)",
    label: () => "up to date",
    title: "Committed run, and no commit has touched this notebook's code, the shared helpers, or the CLI since. Checkout the commit and re-run to reproduce.",
  },
  patched: {
    color: "var(--color-cat-blue)",
    label: () => "reproducible (patched)",
    title: "Ran with uncommitted code, but the working-tree diff was captured. Reproduce: checkout the commit, git apply the patch, re-run.",
  },
  stale: {
    color: "var(--color-cat-orange)",
    label: (pv) =>
      `${pv.commitsSince} commit${pv.commitsSince === 1 ? "" : "s"} behind`,
    title: "Code this run depended on has changed since it was run — the published figures may be out of date.",
  },
  irreproducible: {
    color: "var(--color-danger)",
    label: () => "irreproducible",
    title: "No commit to reconstruct from (or uncommitted code that was not captured) — this run cannot be reproduced.",
  },
  unknown: {
    color: "var(--color-muted)",
    label: () => "run not recorded",
    title: "No run manifest for this entry — provenance was not captured. The date, if any, is the last commit that touched its figures.",
  },
};

const meta = STATE_META[p.state];
const runDate = fmtDate(p.runAt);
const short = p.sha ? p.sha.slice(0, 7) : null;
const changedTitle =
  p.state === "stale" && p.changedFiles?.length
    ? `Changed since run:\n${p.changedFiles.join("\n")}`
    : meta.title;

// The date item: a real manifest gives a run id + run date ("r037 · 2 Jul");
// a backfilled entry (no manifest) has only the figures-dir commit date, so
// it is labelled honestly as such rather than implying a recorded run.
const dateItem = runDate
  ? p.runId
    ? { prefix: p.runId, mono: true, date: runDate }
    : { prefix: "figures dated", mono: false, date: runDate }
  : null;

// Nothing worth showing for an untouched stub.
const render = p.state !== "unknown" || runDate != null;
---

{render && (
  <div class="nb-status not-prose" title={changedTitle}>
    <span class="item status">
      <span class="pip" style={`background:${meta.color}`} aria-hidden="true"></span>
      <span class="state" style={`color:${meta.color}`}>{meta.label(p)}</span>
    </span>
    <span class="right">
      {dateItem && (
        <span class="item">
          <span class={dateItem.mono ? "mono" : ""}>{dateItem.prefix}</span>
          {" "}
          {dateItem.date}
        </span>
      )}
      {short && (
        <span class="item">
          locked to{" "}
          <a class="mono" href={commitUrl(p.sha!)} target="_blank" rel="noopener">
            {short}
          </a>
        </span>
      )}
      {p.hasPatch && (
        <span class="item">
          {"+ "}
          <a
            class="mono"
            href={blobUrl(`src/docs/public/figures/notebooks/${slug}/_dirty.patch`)}
            target="_blank"
            rel="noopener"
          >
            patch{p.patchLines != null ? ` (${p.patchLines} lines)` : ""}
          </a>
        </span>
      )}
      {p.host && p.host !== "local" && (
        <span class="item mono">{p.host}</span>
      )}
    </span>
  </div>
)}

<style>
  .nb-status {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem 1.5rem;
    margin: -0.25rem 0 1.75rem 0;
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--color-rule);
    border-radius: 2px;
    background: var(--color-paper-tint);
    font-family: var(--font-mono, monospace);
    font-size: 0.78rem;
    color: var(--color-muted);
    width: 100%;
  }
  .nb-status .item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    white-space: nowrap;
  }
  .nb-status .right {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1.5rem;
  }
  .nb-status .pip {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    flex: none;
  }
  .nb-status .state {
    font-weight: 600;
  }
  .nb-status .mono {
    font-family: var(--font-mono, monospace);
  }
  .nb-status a.mono {
    color: var(--color-dim);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .nb-status a.mono:hover {
    color: var(--color-ink);
  }
</style>
