---
import { normalizeStatus, STATUS_META } from "../config/status";
const { status, class: extra = "" } = Astro.props as {
  status?: unknown;
  class?: string;
};
const s = normalizeStatus(status);
const meta = STATUS_META[s];
---

<span
  class:list={["text-[0.85rem] text-muted-soft whitespace-nowrap", extra]}
  title={meta.description}
>
  {meta.label}
</span>
