---
/**
 * Progressive-enhancement citation layer for an article.
 *
 * Drop `<Citations references={references} />` once anywhere in an entry. On
 * load it (1) tags the §References list items with `id="ref-N"` anchors, and
 * (2) rewrites every inline `[N]` / `[N, M]` marker in the prose into a
 * linked, hoverable citation: the number jumps to the reference, and a
 * Wikipedia-style card on hover shows the paper title + a direct link.
 *
 * It walks text nodes and skips anything inside math (`.katex`), code, links,
 * or the reference list itself — so a math interval like $[5, 150]$ is never
 * mistaken for a citation. Without JS the plain `[N]` text remains readable,
 * so nothing is lost. References are the single source (see the data file), so
 * a card can't drift from the list.
 */
interface Reference {
  n: number;
  label: string;
  url: string;
  year?: string;
}
const { references = [] } = Astro.props as { references: Reference[] };
const json = JSON.stringify(references);
---

<script type="application/json" data-citations set:html={json} />

<script is:inline>
  (function () {
    const el = document.querySelector("script[data-citations]");
    if (!el) return;
    const refs = JSON.parse(el.textContent || "[]");
    const byN = new Map(refs.map((r) => [r.n, r]));

    const article = document.querySelector("article.prose") || document.body;

    // (1) Anchor the reference list: find the "References" heading, then its
    // next <ol>, and id each item ref-1, ref-2, …
    let refList = null;
    const heads = article.querySelectorAll("h1,h2,h3");
    for (const h of heads) {
      if (/references/i.test(h.textContent || "")) {
        let sib = h.nextElementSibling;
        while (sib && sib.tagName !== "OL") sib = sib.nextElementSibling;
        refList = sib;
        break;
      }
    }
    if (refList) {
      Array.from(refList.children).forEach((li, i) => {
        li.id = "ref-" + (i + 1);
      });
    }

    // (2) Rewrite inline [N] / [N, M] markers in prose text nodes.
    const escapeHtml = (s) =>
      s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    const mdEm = (s) => escapeHtml(s).replace(/\*(.+?)\*/g, "<em>$1</em>");

    const skip = (node) => {
      let p = node.parentElement;
      while (p && p !== article) {
        const tag = p.tagName;
        const cls = typeof p.className === "string" ? p.className : "";
        if (
          tag === "A" ||
          tag === "CODE" ||
          tag === "PRE" ||
          cls.indexOf("katex") !== -1 ||
          p === refList
        )
          return true;
        p = p.parentElement;
      }
      return false;
    };

    const walker = document.createTreeWalker(article, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        if (!node.nodeValue || node.nodeValue.indexOf("[") === -1)
          return NodeFilter.FILTER_REJECT;
        if (!/\[\d/.test(node.nodeValue)) return NodeFilter.FILTER_REJECT;
        return skip(node) ? NodeFilter.FILTER_REJECT : NodeFilter.FILTER_ACCEPT;
      },
    });
    const targets = [];
    let cur;
    while ((cur = walker.nextNode())) targets.push(cur);

    const re = /\[(\d+(?:\s*,\s*\d+)*)\]/g;

    const makeCite = (num) => {
      const ref = byN.get(parseInt(num, 10));
      const a = document.createElement("a");
      a.className = "cite-num";
      a.textContent = num;
      if (!ref) return a; // unknown number → plain link-less number
      a.href = "#ref-" + num;
      const wrap = document.createElement("span");
      wrap.className = "cite";
      const card = document.createElement("span");
      card.className = "cite-card";
      card.setAttribute("role", "note");
      card.innerHTML =
        '<span class="cite-label">' +
        mdEm(ref.label) +
        (ref.year ? " (" + escapeHtml(ref.year) + ")" : "") +
        "</span>";
      const link = document.createElement("a");
      link.className = "cite-link";
      link.href = ref.url;
      link.target = "_blank";
      link.rel = "noopener";
      link.textContent = "View paper ↗";
      card.appendChild(link);
      wrap.appendChild(a);
      wrap.appendChild(card);
      return wrap;
    };

    targets.forEach((node) => {
      const text = node.nodeValue;
      re.lastIndex = 0;
      if (!re.test(text)) return;
      re.lastIndex = 0;
      const frag = document.createDocumentFragment();
      let last = 0;
      let m;
      while ((m = re.exec(text))) {
        frag.appendChild(document.createTextNode(text.slice(last, m.index)));
        const nums = m[1].split(",").map((s) => s.trim());
        frag.appendChild(document.createTextNode("["));
        nums.forEach((num, i) => {
          if (i) frag.appendChild(document.createTextNode(", "));
          frag.appendChild(makeCite(num));
        });
        frag.appendChild(document.createTextNode("]"));
        last = m.index + m[0].length;
      }
      frag.appendChild(document.createTextNode(text.slice(last)));
      node.parentNode.replaceChild(frag, node);
    });
  })();
</script>

<style is:global>
  .cite {
    position: relative;
    display: inline;
  }
  .cite-num {
    color: var(--color-dim);
    text-decoration: underline;
    text-underline-offset: 2px;
    cursor: pointer;
  }
  .cite:hover .cite-num {
    color: var(--color-ink);
  }
  .cite-card {
    position: absolute;
    left: 0;
    top: 1.5em;
    z-index: 40;
    display: block;
    width: max-content;
    max-width: 22rem;
    /* transparent bridge so the mouse can cross into the card without a gap */
    padding: 0.6rem 0.7rem;
    border: 1px solid var(--color-rule);
    border-radius: 3px;
    background: var(--color-paper, #fff);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    font-family: var(--font-serif);
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--color-ink);
    /* hidden until hover/focus */
    opacity: 0;
    visibility: hidden;
    transform: translateY(-2px);
    transition: opacity 0.12s ease, transform 0.12s ease, visibility 0.12s;
  }
  /* Transparent bridge over the gap between the number and the card, so the
     pointer can travel into the card (to click the link) without the pure-CSS
     hover dropping. */
  .cite-card::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: -0.7em;
    height: 0.7em;
  }
  .cite:hover .cite-card,
  .cite:focus-within .cite-card {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .cite-label {
    display: block;
    margin-bottom: 0.4rem;
    color: var(--color-ink);
  }
  .cite-link {
    color: var(--color-dim);
    text-decoration: underline;
    text-underline-offset: 2px;
    font-family: var(--font-mono, monospace);
    font-size: 0.76rem;
    white-space: nowrap;
  }
  .cite-link:hover {
    color: var(--color-ink);
  }
</style>
