---
/**
 * Command palette: press `f` anywhere to open a search box, type a collection /
 * article / notebook id or name, and jump to it. Arrow keys move the
 * selection, Enter navigates, Escape (or a backdrop click) closes.
 *
 * The full entry list is embedded at build time (below), so the palette is
 * instant and needs no network. Rendered once via SiteHeader.
 */
import { getCollection } from "astro:content";
import { collectionLabel } from "../config/collections";

const articles = await getCollection("articles");
const notebooks = await getCollection("notebooks");
const strip = (t: unknown) => String(t).replace(/^\d+\s*[—–-]\s*/, "");

const slugs = new Set<string>();
for (const e of [...articles, ...notebooks]) {
  if (e.data.collection) slugs.add(e.data.collection);
}

type Item = { kind: string; id: string; title: string; url: string; sub: string };
const items: Item[] = [
  ...[...slugs].map((s) => ({
    kind: "collection",
    id: s,
    title: collectionLabel(s),
    url: `/collections/${s}/`,
    sub: "Collection",
  })),
  ...articles.map((e) => ({
    kind: "article",
    id: e.id,
    title: strip(e.data.title),
    url: `/articles/${e.id}/`,
    sub: e.data.collection ? collectionLabel(e.data.collection) : "Article",
  })),
  ...notebooks.map((e) => ({
    kind: "notebook",
    id: e.id,
    title: strip(e.data.title),
    url: `/notebooks/${e.id}/`,
    sub: e.data.collection ? collectionLabel(e.data.collection) : "Notebook",
  })),
];
const json = JSON.stringify(items);
---

<div class="palette" data-palette hidden>
  <div class="palette-backdrop" data-palette-close></div>
  <div class="palette-box" role="dialog" aria-modal="true" aria-label="Jump to entry">
    <input
      class="palette-input"
      type="text"
      placeholder="Jump to a collection, article, or notebook — id or name…"
      autocomplete="off"
      spellcheck="false"
    />
    <ul class="palette-results"></ul>
  </div>
</div>
<script type="application/json" data-palette-data set:html={json} />

<script is:inline>
  (function () {
    const root = document.querySelector("[data-palette]");
    if (!root) return;
    const input = root.querySelector(".palette-input");
    const list = root.querySelector(".palette-results");
    const items = JSON.parse(
      document.querySelector("[data-palette-data]").textContent || "[]",
    );

    let open = false;
    let filtered = [];
    let sel = 0;

    const isField = (el) =>
      !!el &&
      (el.tagName === "INPUT" ||
        el.tagName === "TEXTAREA" ||
        el.tagName === "SELECT" ||
        el.isContentEditable);

    const esc = (s) =>
      String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

    function score(it, q) {
      const id = it.id.toLowerCase();
      const title = it.title.toLowerCase();
      if (id === q) return 0;
      if (id.startsWith(q)) return 1;
      if (title.startsWith(q)) return 2;
      if (id.includes(q)) return 3;
      if (title.includes(q)) return 4;
      return 99;
    }

    function render() {
      const q = input.value.trim().toLowerCase();
      filtered = (q
        ? items
            .map((it) => [it, score(it, q)])
            .filter((p) => p[1] < 99)
            .sort((a, b) => a[1] - b[1])
            .map((p) => p[0])
        : items
      ).slice(0, 40);
      sel = 0;
      list.innerHTML = filtered
        .map(
          (it, i) =>
            '<li class="palette-item' +
            (i === sel ? " sel" : "") +
            '" data-url="' +
            esc(it.url) +
            '"><span class="pi-id">' +
            esc(it.id) +
            '</span><span class="pi-title">' +
            esc(it.title) +
            '</span><span class="pi-sub">' +
            esc(it.sub) +
            "</span></li>",
        )
        .join("");
    }

    function move(d) {
      if (!filtered.length) return;
      sel = (sel + d + filtered.length) % filtered.length;
      const els = list.querySelectorAll(".palette-item");
      els.forEach((el, i) => el.classList.toggle("sel", i === sel));
      const cur = els[sel];
      if (cur) cur.scrollIntoView({ block: "nearest" });
    }

    function go() {
      const it = filtered[sel];
      if (it) location.href = it.url;
    }

    function openPalette() {
      open = true;
      root.hidden = false;
      input.value = "";
      render();
      input.focus();
    }
    function closePalette() {
      open = false;
      root.hidden = true;
      input.blur();
    }

    // `f` opens (when not typing / no modifier).
    document.addEventListener("keydown", (e) => {
      if (open) return;
      if (e.key !== "f") return;
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      if (isField(document.activeElement)) return;
      e.preventDefault();
      openPalette();
    });

    input.addEventListener("input", render);
    input.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown") {
        e.preventDefault();
        move(1);
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        move(-1);
      } else if (e.key === "Enter") {
        e.preventDefault();
        go();
      } else if (e.key === "Escape") {
        e.preventDefault();
        closePalette();
      }
    });
    list.addEventListener("click", (e) => {
      const li = e.target.closest(".palette-item");
      if (li && li.dataset.url) location.href = li.dataset.url;
    });
    root.querySelector("[data-palette-close]").addEventListener("click", closePalette);
  })();
</script>

<style is:global>
  .palette[hidden] {
    display: none;
  }
  .palette {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 12vh;
  }
  .palette-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.28);
  }
  .palette-box {
    position: relative;
    width: min(38rem, calc(100vw - 2rem));
    max-height: 70vh;
    display: flex;
    flex-direction: column;
    background: var(--color-paper, #fff);
    border: 1px solid var(--color-rule);
    border-radius: 4px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.22);
    overflow: hidden;
  }
  .palette-input {
    padding: 0.8rem 1rem;
    border: 0;
    border-bottom: 1px solid var(--color-rule);
    background: transparent;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: 1rem;
    outline: none;
  }
  .palette-results {
    margin: 0;
    padding: 0.3rem 0;
    list-style: none;
    overflow-y: auto;
  }
  .palette-item {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    padding: 0.4rem 1rem;
    cursor: pointer;
    font-family: var(--font-serif);
  }
  .palette-item.sel {
    background: var(--color-paper-tint);
  }
  .pi-id {
    flex: none;
    width: 3.4rem;
    font-family: var(--font-mono, monospace);
    font-size: 0.78rem;
    color: var(--color-muted-soft);
  }
  .pi-title {
    flex: 1 1 auto;
    min-width: 0;
    color: var(--color-ink);
    font-size: 0.92rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .pi-sub {
    flex: none;
    color: var(--color-muted-soft);
    font-size: 0.75rem;
    white-space: nowrap;
  }
</style>
