---
import { blobUrl } from "../config/repo";

interface Props {
  path: string;
  line?: number;
  range?: [number, number];
  sha?: string;
  children?: any;
}

const { path, line, range, sha } = Astro.props as Props;
const href = blobUrl(path, { sha, line, range });

const lineSuffix = range
  ? `:${range[0]}-${range[1]}`
  : line != null
    ? `:${line}`
    : "";
const defaultLabel = `${path}${lineSuffix}`;
---
<a href={href} class="font-mono text-[0.92em] decoration-1 underline-offset-[0.2em]" target="_blank" rel="noopener">
  <slot>{defaultLabel}</slot>
</a>
