---
import { blobUrl } from "../config/repo";

interface Props {
  path: string;
  line?: number;
  range?: [number, number];
  sha?: string;
  children?: any;
}

const { path, line, range, sha } = Astro.props as Props;
const href = blobUrl(path, { sha, line, range });

const lineSuffix = range
  ? `:${range[0]}-${range[1]}`
  : line != null
    ? `:${line}`
    : "";
const defaultLabel = `${path}${lineSuffix}`;
---
<a href={href} class="code-link" target="_blank" rel="noopener">
  <slot>{defaultLabel}</slot>
</a>

<style>
  .code-link {
    font-family: var(--font-mono, ui-monospace, Menlo, monospace);
    font-size: 0.92em;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }
</style>
