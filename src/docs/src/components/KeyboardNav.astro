---
/**
 * Keyboard link navigation for the content pages (articles, notebooks,
 * collections, index).
 *
 * ← / → move focus to the previous / next link *within the page's <main>*
 * (DOM order, wrapping); Enter activates the focused link (native <a>, so
 * in-page anchors like citations and section refs jump, external links open).
 *
 * Scoped to `<main>` — the content region on every page — so it cycles entry
 * and listing links but never the site-header nav chrome. Arrows are ignored
 * while typing in a field or with a modifier held. Only visible links are
 * targets (a collapsed citation card is skipped).
 *
 * Rendered once via SiteHeader, so every page loads it.
 */
---

<script is:inline>
  (function () {
    const isField = (el) =>
      !!el &&
      (el.tagName === "INPUT" ||
        el.tagName === "TEXTAREA" ||
        el.tagName === "SELECT" ||
        el.isContentEditable);

    // Scope to the entry content only. Looked up lazily (this script runs in
    // the header, before <article> is parsed) — absent on index/collection
    // pages, so the feature stays inert there.
    const visibleLinks = () => {
      const scope = document.querySelector("main");
      if (!scope) return [];
      const vis = Array.from(scope.querySelectorAll("a[href]")).filter((a) => {
        if (a.offsetParent === null) return false; // display:none / detached
        const cs = getComputedStyle(a);
        return cs.visibility !== "hidden" && parseFloat(cs.opacity || "1") > 0.05;
      });
      // Listing rows link the same entry twice (id, then title) — drop the
      // first so a stop lands only on the title.
      return vis.filter((a, i) => !(vis[i + 1] && vis[i + 1].href === a.href));
    };

    // Capture phase so a stopPropagation() somewhere on the bubble path can't
    // swallow the arrows before we see them.
    document.addEventListener("keydown", (e) => {
      if (e.key !== "ArrowRight" && e.key !== "ArrowLeft") return;
      if (e.metaKey || e.ctrlKey || e.altKey || e.shiftKey) return;
      if (isField(document.activeElement)) return;

      const links = visibleLinks();
      if (!links.length) return;

      const idx = links.indexOf(document.activeElement);
      let next;
      if (e.key === "ArrowRight") {
        next = links[idx < 0 ? 0 : (idx + 1) % links.length];
      } else {
        next = links[idx < 0 ? links.length - 1 : (idx - 1 + links.length) % links.length];
      }
      e.preventDefault();
      next.focus({ preventScroll: true });
      next.scrollIntoView({ block: "center", behavior: "smooth" });
      // Highlight the arrow-focused link. Done via inline !important styles
      // because the site forces text-decoration:none on links inside <main>
      // with an !important utility that a stylesheet rule can't reliably beat.
      mark(next);
    }, true);

    const UNDERLINE = [
      ["outline", "none"], // suppress the browser's default focus box
      ["text-decoration-line", "underline"],
      ["text-decoration-color", "var(--color-muted)"],
      ["text-decoration-thickness", "2px"],
      ["text-underline-offset", "3px"],
    ];
    let marked = null;
    function style(el, on) {
      UNDERLINE.forEach(([p, v]) => {
        if (on) el.style.setProperty(p, v, "important");
        else el.style.removeProperty(p);
      });
    }
    function mark(el) {
      if (marked && marked !== el) style(marked, false);
      marked = el;
      if (el) style(el, true);
    }
    const clear = () => mark(null);
    // Drop the ring the moment the user switches to the mouse or focus leaves.
    document.addEventListener("pointerdown", clear, true);
    document.addEventListener(
      "focusout",
      (e) => {
        if (e.target === marked) clear();
      },
      true,
    );
  })();
</script>
