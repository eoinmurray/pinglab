index 0000000..ebdb679
--- /dev/null
+++ b/src/cli/tests/test_datasets_coverage.py
@@ -0,0 +1,111 @@
+"""Coverage for datasets.py — the SHD loader and load_dataset branches.
+
+The SHD loader normally reads the official ~10k-sample HDF5 files. Here we build a
+tiny synthetic pair with the same layout (labels + ragged spikes/times, spikes/units)
+so the binning path, the missing-file error, and the load_dataset dispatch branches
+are all exercised without the real dataset on disk.
+"""
+
+from __future__ import annotations
+
+import numpy as np
+import pytest
+from datasets import (
+    SHD_N_CHANNELS,
+    _load_dataset_image,
+    _load_shd,
+    _shd_cache_dir,
+    load_dataset,
+)
+
+
+def _make_synthetic_shd(path, n, seed):
+    """Write an HDF5 file matching the SHD layout: labels + vlen event arrays."""
+    import h5py
+
+    rng = np.random.RandomState(seed)
+    vt = h5py.special_dtype(vlen=np.dtype("float64"))
+    vu = h5py.special_dtype(vlen=np.dtype("int64"))
+    with h5py.File(path, "w") as f:
+        # Cycle a few classes (not random) so every class has >=2 members and a
+        # stratified 80/20 split is valid on the concatenated train+test set.
+        f["labels"] = (np.arange(n) % 4).astype(np.int64)
+        times = f.create_dataset("spikes/times", (n,), dtype=vt)
+        units = f.create_dataset("spikes/units", (n,), dtype=vu)
+        for i in range(n):
+            k = int(rng.randint(5, 15))
+            times[i] = rng.uniform(0.0, 0.9, size=k)  # event times in seconds
+            units[i] = rng.randint(0, SHD_N_CHANNELS, size=k)
+
+
+@pytest.fixture
+def shd_cache(tmp_path, monkeypatch):
+    """Point $PINGLAB_SHD_DIR at a synthetic train+test HDF5 pair."""
+    monkeypatch.setenv("PINGLAB_SHD_DIR", str(tmp_path))
+    _make_synthetic_shd(tmp_path / "shd_train.h5", n=12, seed=1)
+    _make_synthetic_shd(tmp_path / "shd_test.h5", n=8, seed=2)
+    return tmp_path
+
+
+def test_shd_cache_dir_env_override(tmp_path, monkeypatch):
+    monkeypatch.setenv("PINGLAB_SHD_DIR", str(tmp_path / "somewhere"))
+    assert _shd_cache_dir() == str(tmp_path / "somewhere")
+
+
+def test_shd_cache_dir_default(monkeypatch):
+    monkeypatch.delenv("PINGLAB_SHD_DIR", raising=False)
+    assert _shd_cache_dir() == "/tmp/shd/SHD"
+
+
+def test_load_shd_bins_events_to_dense_raster(shd_cache):
+    dt_ms, t_ms = 2.0, 100.0
+    X, y = _load_shd(dt_ms=dt_ms, t_ms=t_ms)
+    T_steps = int(round(t_ms / dt_ms))
+    assert X.shape == (20, T_steps, SHD_N_CHANNELS)  # 12 train + 8 test
+    assert y.shape == (20,)
+    assert X.dtype == np.float32
+    # dense binary raster: multiple events per (t, unit) collapse to 1.0
+    assert set(np.unique(X)).issubset({0.0, 1.0})
+    assert X.sum() > 0
+
+
+def test_load_shd_per_file_cap(shd_cache):
+    X, y = _load_shd(dt_ms=2.0, t_ms=100.0, max_samples=5)
+    assert X.shape[0] == 10  # 5 per file × 2 files
+    assert len(y) == 10
+
+
+def test_load_shd_missing_files_raises(tmp_path, monkeypatch):
+    monkeypatch.setenv("PINGLAB_SHD_DIR", str(tmp_path))  # empty dir
+    with pytest.raises(FileNotFoundError, match="SHD HDF5 files not found"):
+        _load_shd(dt_ms=1.0, t_ms=100.0)
+
+
+def test_load_dataset_shd_dispatch(shd_cache):
+    X, y = load_dataset("shd", dt_ms=2.0, t_ms=100.0, max_samples=5)
+    assert X.ndim == 3
+    assert X.shape[-1] == SHD_N_CHANNELS
+    assert len(X) == len(y)
+
+
+def test_load_dataset_shd_requires_dt_and_t(shd_cache):
+    with pytest.raises(ValueError, match="requires dt_ms and t_ms"):
+        load_dataset("shd")
+
+
+def test_load_dataset_shd_split(shd_cache):
+    X_tr, X_te, y_tr, y_te = load_dataset(
+        "shd", dt_ms=2.0, t_ms=100.0, split=True
+    )
+    assert len(X_tr) + len(X_te) == 20
+    assert len(y_te) == len(X_te)
+
+
+def test_load_dataset_unknown_name_raises():
+    with pytest.raises(ValueError, match="Unknown dataset"):
+        load_dataset("not_a_dataset")
+
+
+def test_load_dataset_image_unknown_raises():
+    with pytest.raises(ValueError, match="Unknown dataset"):
+        _load_dataset_image(dataset="not_a_dataset")

diff --git a/src/cli/tests/test_infer_coverage.py b/src/cli/tests/test_infer_coverage.py
