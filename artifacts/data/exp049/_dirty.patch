+        opt = torch.optim.SGD([param], lr=1.0)
+        opt.register_step_post_hook(lambda *_: net.project_dales())
+        param.grad = torch.ones_like(param)
+
+        opt.step()
+
+        assert torch.count_nonzero(param).item() == 0
